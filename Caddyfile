:80 {
	# Serve static files from Astro build output
	root * /var/www/joekarlsson.com

	# 301 redirects: WordPress date-based blog URLs → /blog/slug
	# Matches /YYYY/MM/slug/ or /YYYY/MM/slug
	@wp-blog path_regexp wp ^/(\d{4})/(\d{2})/([a-z0-9-]+)/?$
	redir @wp-blog /blog/{re.wp.3} 301

	# 301 redirects: WordPress page URLs
	@speaking path /speaking /speaking/ /speaking/joe-karlssons-talk-archive /speaking/joe-karlssons-talk-archive/
	redir @speaking /talk-archive 301

	@all-work path /all-work /all-work/
	redir @all-work /work 301

	# WordPress feed → RSS
	@feed path /feed /feed/
	redir @feed /rss.xml 301

	# WordPress remnants — return 410 Gone
	@wp-remnants path /xmlrpc.php /wp-admin* /wp-login.php /wp-content* /wp-includes* /wp-json*
	respond @wp-remnants 410

	# Serve files, fall back to 404
	file_server
	handle_errors {
		rewrite * /404.html
		file_server
	}

	# Security headers
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://plausible.joekarlsson.io https://www.tiktok.com https://*.tiktokcdn-us.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://*.tiktokcdn-us.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; frame-src https://www.youtube.com https://www.youtube-nocookie.com https://www.tiktok.com https://*.tiktok.com; connect-src 'self' https://plausible.joekarlsson.io https://cloudflareinsights.com https://www.tiktok.com https://*.tiktok.com"
	}

	# Cache static assets with hashed filenames - immutable and long-lived
	# Astro generates unique hashes for CSS/JS, so they can be cached forever
	@static path *.css *.js *.svg *.png *.jpg *.jpeg *.webp *.woff2 *.woff *.ttf *.gif
	header @static Cache-Control "public, max-age=31536000, immutable"

	# HTML pages: always revalidate with origin to prevent stale cache
	# This ensures users always get fresh HTML that references current CSS/JS hashes
	# - no-cache: must revalidate before using cached copy
	# - s-maxage=0: CDNs must not cache (prevents the HTML/CSS mismatch bug)
	# - must-revalidate: treat stale responses as errors
	@html path *.html /
	header @html Cache-Control "no-cache, s-maxage=0, must-revalidate"
}
