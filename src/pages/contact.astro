---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SOCIAL_LINKS } from '../consts';
---

<BaseLayout
	title="Contact | Joe Karlsson"
	description="Connect with Joe Karlsson - find me on Bluesky, LinkedIn, GitHub, YouTube, and more. Book me for speaking engagements or just say hi."
	schemaType="ContactPage"
>
	<div class="mx-auto max-w-3xl px-4 py-8">
		<p class="mb-2 font-mono text-sm text-coral" aria-hidden="true">~$ cat contact.md</p>
		<h1 class="mb-2 text-3xl font-bold text-coral md:text-4xl">Ready to be friends?</h1>
		<p class="mb-8 text-gray-400">
			I'm always up for talking databases, smart homes, dev tools, or whatever weird project you're
			working on. The best way to reach me is through one of the platforms below - I'm most active
			on Bluesky and LinkedIn.
		</p>

		<!-- Newsletter -->
		<div class="mb-10 rounded-lg border border-teal/20 bg-teal/5 p-6">
			<h2 class="mb-2 text-lg font-bold text-white">
				<span class="text-coral font-mono text-sm" aria-hidden="true">~$</span> cat newsletter.md
			</h2>
			<p class="mb-3 text-sm text-gray-400">
				Each week, a curated collection of articles about tech with my personal summary and
				opinions.
			</p>
			<a
				href={SOCIAL_LINKS.substack}
				target="_blank"
				rel="noopener noreferrer"
				class="inline-block rounded-md bg-teal px-4 py-2 text-sm font-medium text-surface-0 no-underline hover:bg-coral"
			>
				Subscribe on Substack &rarr;
			</a>
		</div>

		<!-- Primary -->
		<h2 class="mb-4 text-lg font-semibold text-white">
			<span class="text-coral font-mono text-sm" aria-hidden="true">~$</span> ls socials/
		</h2>
		<div class="mb-8 grid gap-3 sm:grid-cols-2">
			<a
				href={SOCIAL_LINKS.bluesky}
				target="_blank"
				rel="noopener noreferrer"
				class="flex items-center gap-3 rounded-lg border border-surface-3 bg-surface-1 p-4 no-underline transition-colors hover:border-coral/30 hover:bg-surface-2"
			>
				<span class="text-xl text-sky" aria-hidden="true">&#9729;</span>
				<div>
					<p class="font-medium text-white">Bluesky</p>
					<p class="text-xs text-gray-400">@joekarlsson.com</p>
				</div>
			</a>
			<a
				href={SOCIAL_LINKS.linkedin}
				target="_blank"
				rel="noopener noreferrer"
				class="flex items-center gap-3 rounded-lg border border-surface-3 bg-surface-1 p-4 no-underline transition-colors hover:border-coral/30 hover:bg-surface-2"
			>
				<span class="text-xl text-sky" aria-hidden="true">in</span>
				<div>
					<p class="font-medium text-white">LinkedIn</p>
					<p class="text-xs text-gray-400">Professional inquiries & speaking</p>
				</div>
			</a>
			<a
				href={SOCIAL_LINKS.threads}
				target="_blank"
				rel="noopener noreferrer"
				class="flex items-center gap-3 rounded-lg border border-surface-3 bg-surface-1 p-4 no-underline transition-colors hover:border-coral/30 hover:bg-surface-2"
			>
				<span class="text-xl text-white" aria-hidden="true">@</span>
				<div>
					<p class="font-medium text-white">Threads</p>
					<p class="text-xs text-gray-400">@joekarlsson</p>
				</div>
			</a>
			<a
				href={SOCIAL_LINKS.github}
				target="_blank"
				rel="noopener noreferrer"
				class="flex items-center gap-3 rounded-lg border border-surface-3 bg-surface-1 p-4 no-underline transition-colors hover:border-coral/30 hover:bg-surface-2"
			>
				<span class="text-xl text-white" aria-hidden="true">GH</span>
				<div>
					<p class="font-medium text-white">GitHub</p>
					<p class="text-xs text-gray-400">Open source & projects</p>
				</div>
			</a>
		</div>

		<!-- Video & Audio -->
		<h2 class="mb-4 text-lg font-semibold text-white">
			<span class="text-coral font-mono text-sm" aria-hidden="true">~$</span> ls media/
		</h2>
		<div class="mb-8 grid gap-3 sm:grid-cols-2">
			<a
				href={SOCIAL_LINKS.youtube}
				target="_blank"
				rel="noopener noreferrer"
				class="flex items-center gap-3 rounded-lg border border-surface-3 bg-surface-1 p-4 no-underline transition-colors hover:border-coral/30 hover:bg-surface-2"
			>
				<span class="text-xl text-terminal-red" aria-hidden="true">&#9654;</span>
				<div>
					<p class="font-medium text-white">YouTube</p>
					<p class="text-xs text-gray-400">Talks & tutorials</p>
				</div>
			</a>
			<a
				href={SOCIAL_LINKS.twitch}
				target="_blank"
				rel="noopener noreferrer"
				class="flex items-center gap-3 rounded-lg border border-surface-3 bg-surface-1 p-4 no-underline transition-colors hover:border-coral/30 hover:bg-surface-2"
			>
				<span class="text-xl text-lavender" aria-hidden="true">&#9654;</span>
				<div>
					<p class="font-medium text-white">Twitch</p>
					<p class="text-xs text-gray-400">Live coding & hangouts</p>
				</div>
			</a>
			<a
				href={SOCIAL_LINKS.spotify}
				target="_blank"
				rel="noopener noreferrer"
				class="flex items-center gap-3 rounded-lg border border-surface-3 bg-surface-1 p-4 no-underline transition-colors hover:border-coral/30 hover:bg-surface-2"
			>
				<span class="text-xl text-terminal-green" aria-hidden="true">&#9835;</span>
				<div>
					<p class="font-medium text-white">Spotify</p>
					<p class="text-xs text-gray-400">Playlists & listening</p>
				</div>
			</a>
			<a
				href={SOCIAL_LINKS.tiktok}
				target="_blank"
				rel="noopener noreferrer"
				class="flex items-center gap-3 rounded-lg border border-surface-3 bg-surface-1 p-4 no-underline transition-colors hover:border-coral/30 hover:bg-surface-2"
			>
				<span class="text-xl text-pink" aria-hidden="true">&#9835;</span>
				<div>
					<p class="font-medium text-white">TikTok</p>
					<p class="text-xs text-gray-400">@joekarlsson</p>
				</div>
			</a>
		</div>

		<!-- Other -->
		<h2 class="mb-4 text-lg font-semibold text-white">
			<span class="text-coral font-mono text-sm" aria-hidden="true">~$</span> ls other/
		</h2>
		<div class="mb-8 grid gap-3 sm:grid-cols-2">
			<a
				href={SOCIAL_LINKS.instagram}
				target="_blank"
				rel="noopener noreferrer"
				class="flex items-center gap-3 rounded-lg border border-surface-3 bg-surface-1 p-4 no-underline transition-colors hover:border-coral/30 hover:bg-surface-2"
			>
				<span class="text-xl text-pink" aria-hidden="true">&#128247;</span>
				<div>
					<p class="font-medium text-white">Instagram</p>
					<p class="text-xs text-gray-400">Photos & stories</p>
				</div>
			</a>
			<a
				href={SOCIAL_LINKS.letterboxd}
				target="_blank"
				rel="noopener noreferrer"
				class="flex items-center gap-3 rounded-lg border border-surface-3 bg-surface-1 p-4 no-underline transition-colors hover:border-coral/30 hover:bg-surface-2"
			>
				<span class="text-xl text-terminal-green" aria-hidden="true">&#127916;</span>
				<div>
					<p class="font-medium text-white">Letterboxd</p>
					<p class="text-xs text-gray-400">Movie reviews & lists</p>
				</div>
			</a>
			<a
				href={SOCIAL_LINKS.twitter}
				target="_blank"
				rel="noopener noreferrer"
				class="flex items-center gap-3 rounded-lg border border-surface-3 bg-surface-1 p-4 no-underline transition-colors hover:border-coral/30 hover:bg-surface-2"
			>
				<span class="text-xl text-gray-500" aria-hidden="true">&#120143;</span>
				<div>
					<p class="font-medium text-white">Twitter/X</p>
					<p class="text-xs text-gray-400">Legacy account</p>
				</div>
			</a>
			<a
				href={SOCIAL_LINKS.reddit}
				target="_blank"
				rel="noopener noreferrer"
				class="flex items-center gap-3 rounded-lg border border-surface-3 bg-surface-1 p-4 no-underline transition-colors hover:border-coral/30 hover:bg-surface-2"
			>
				<span class="text-xl text-terminal-yellow" aria-hidden="true">&#128172;</span>
				<div>
					<p class="font-medium text-white">Reddit</p>
					<p class="text-xs text-gray-400">Lurking & commenting</p>
				</div>
			</a>
			<a
				href={SOCIAL_LINKS.medium}
				target="_blank"
				rel="noopener noreferrer"
				class="flex items-center gap-3 rounded-lg border border-surface-3 bg-surface-1 p-4 no-underline transition-colors hover:border-coral/30 hover:bg-surface-2"
			>
				<span class="text-xl text-white" aria-hidden="true">M</span>
				<div>
					<p class="font-medium text-white">Medium</p>
					<p class="text-xs text-gray-400">Cross-posted articles</p>
				</div>
			</a>
			<a
				href={SOCIAL_LINKS.npm}
				target="_blank"
				rel="noopener noreferrer"
				class="flex items-center gap-3 rounded-lg border border-surface-3 bg-surface-1 p-4 no-underline transition-colors hover:border-coral/30 hover:bg-surface-2"
			>
				<span class="text-xl text-terminal-red" aria-hidden="true">&#9744;</span>
				<div>
					<p class="font-medium text-white">npm</p>
					<p class="text-xs text-gray-400">Published packages</p>
				</div>
			</a>
		</div>
	</div>
</BaseLayout>
