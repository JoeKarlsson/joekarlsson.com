	<script is:inline>
		function switchView(view) {
			const normalView = document.getElementById('normal-view');
			const aptView = document.getElementById('apt-view');
			const tabNormal = document.getElementById('tab-normal');
			const tabApt = document.getElementById('tab-apt');

			if (view === 'apt') {
				normalView.classList.add('hidden');
				aptView.classList.remove('hidden');
				tabNormal.classList.remove('bg-coral', 'text-black');
				tabNormal.classList.add('bg-surface-1', 'text-gray-400');
				tabNormal.setAttribute('aria-selected', 'false');
				tabApt.classList.remove('bg-surface-1', 'text-gray-400');
				tabApt.classList.add('bg-coral', 'text-black');
				tabApt.setAttribute('aria-selected', 'true');
			} else {
				normalView.classList.remove('hidden');
				aptView.classList.add('hidden');
				tabNormal.classList.remove('bg-surface-1', 'text-gray-400');
				tabNormal.classList.add('bg-coral', 'text-black');
				tabNormal.setAttribute('aria-selected', 'true');
				tabApt.classList.remove('bg-coral', 'text-black');
				tabApt.classList.add('bg-surface-1', 'text-gray-400');
				tabApt.setAttribute('aria-selected', 'false');
			}

			localStorage.setItem('uses-view-preference', view);
		}

		// Restore saved preference on load
		document.addEventListener('DOMContentLoaded', function () {
			const saved = localStorage.getItem('uses-view-preference');
			if (saved === 'apt') {
				switchView('apt');
			}
		});
	</script>
