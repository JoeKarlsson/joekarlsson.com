---
import { getCollection } from 'astro:content';
import BlogCard from '../components/BlogCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION, SOCIAL_LINKS } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 6);
---

<BaseLayout title="Joe Karlsson — Developer Advocate & Massive Nerd" description={SITE_DESCRIPTION}>
	<!-- Hero Terminal -->
	<section class="border-b-4 border-coral overflow-hidden">
		<div class="mx-auto max-w-5xl px-4 md:px-6 py-12 md:py-20">
			<!-- Terminal -->
			<div class="terminal mx-auto text-left rounded-lg overflow-hidden border border-surface-3 shadow-2xl">
				<!-- Title bar -->
				<div class="terminal-titlebar flex items-center gap-2 px-4 py-2 bg-surface-1 border-b border-surface-3">
					<span class="w-3 h-3 rounded-full bg-red-500/80"></span>
					<span class="w-3 h-3 rounded-full bg-yellow-500/80"></span>
					<span class="w-3 h-3 rounded-full bg-green-500/80"></span>
					<span class="ml-2 text-xs text-surface-4 font-mono">joe@joekarlsson.com — bash</span>
				</div>
				<!-- Terminal body -->
				<div
					id="terminal"
					class="terminal-body bg-surface-0 p-4 font-mono text-sm leading-relaxed h-72 md:h-96 overflow-y-auto cursor-text"
					tabindex="0"
					role="application"
					aria-label="Interactive terminal. Type help for available commands."
				>
					<div id="output"></div>
					<div id="input-line" class="flex items-center" style="display:none;">
						<span class="prompt text-coral mr-2">joe@karlsson ~$</span>
						<span id="input-text" class="text-gray-200"></span><span id="cursor" class="cursor">&#9608;</span>
					</div>
					<input
						id="hidden-input"
						type="text"
						class="absolute opacity-0 w-0 h-0 pointer-events-none"
						autocomplete="off"
						autocorrect="off"
						autocapitalize="off"
						spellcheck="false"
					/>
				</div>
			</div>

			<!-- CTA buttons below terminal -->
			<div class="flex flex-wrap gap-3 mt-6 justify-center">
				<a
					href="/blog"
					class="btn-primary rounded-md bg-coral px-5 py-2.5 font-medium text-surface-0 no-underline hover:bg-teal"
				>
					Read the Blog
				</a>
				<a
					href="/about"
					class="btn-secondary rounded-md border border-surface-4 px-5 py-2.5 font-medium text-gray-300 no-underline hover:border-coral hover:text-white"
				>
					About Me
				</a>
				<a
					href="/work"
					class="btn-secondary rounded-md border border-surface-4 px-5 py-2.5 font-medium text-gray-300 no-underline hover:border-coral hover:text-white"
				>
					My Work
				</a>
			</div>
		</div>
	</section>

	<!-- Hero illustration banner -->
	<section class="border-b border-surface-3 bg-surface-1">
		<div class="mx-auto max-w-5xl">
			<img
				src="/images/hero-illustration.webp"
				alt="Illustrated portrait of Joe Karlsson at a computer with a cat"
				class="w-full h-48 sm:h-64 md:h-80 object-cover object-center"
				width="2560"
				height="1707"
				loading="eager"
			/>
		</div>
	</section>

	<!-- What I Do — brutalist grid with thick borders -->
	<section class="border-b-4 border-teal">
		<div class="mx-auto grid max-w-5xl grid-cols-1 sm:grid-cols-3">
			<a href="/blog" class="card-hover group flex items-center gap-4 border-b sm:border-b-0 sm:border-r border-surface-3 px-8 py-8 no-underline transition-all duration-300 hover:bg-coral/5">
				<span class="text-3xl text-coral transition-transform duration-300 group-hover:scale-125 group-hover:rotate-12">&#9998;</span>
				<div>
					<p class="font-medium text-white">Blog</p>
					<p class="text-sm text-gray-500">Databases, smart homes, dev tools</p>
				</div>
			</a>
			<a href="/work" class="card-hover group flex items-center gap-4 border-b sm:border-b-0 sm:border-r border-surface-3 px-8 py-8 no-underline transition-all duration-300 hover:bg-teal/5">
				<span class="text-3xl text-teal transition-transform duration-300 group-hover:scale-125 group-hover:rotate-12">&#9881;</span>
				<div>
					<p class="font-medium text-white">Projects</p>
					<p class="text-sm text-gray-500">Things I've built & shipped</p>
				</div>
			</a>
			<a href="/talk-archive" class="card-hover group flex items-center gap-4 px-8 py-8 no-underline transition-all duration-300 hover:bg-lavender/5">
				<span class="text-3xl text-lavender transition-transform duration-300 group-hover:scale-125 group-hover:rotate-12">&#9654;</span>
				<div>
					<p class="font-medium text-white">Talks</p>
					<p class="text-sm text-gray-500">Conferences & meetups</p>
				</div>
			</a>
		</div>
	</section>

	<!-- Right Now -->
	<section class="border-b border-surface-3">
		<div class="mx-auto max-w-5xl px-6 py-14">
			<h2 class="mb-4 text-lg font-bold text-white">
				<span class="text-teal font-mono text-sm">&gt;</span> Right now
			</h2>
			<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
				<div class="rounded-lg border border-surface-3 bg-surface-1 p-4">
					<p class="text-xs text-gray-600 font-mono mb-1">working on</p>
					<p class="text-sm text-gray-300">Building data pipelines & developer tools at <strong class="text-white">CloudQuery</strong></p>
				</div>
				<div class="rounded-lg border border-surface-3 bg-surface-1 p-4">
					<p class="text-xs text-gray-600 font-mono mb-1">tinkering with</p>
					<p class="text-sm text-gray-300">A <strong class="text-white">40+ container homelab</strong> running Proxmox, Home Assistant, and way too many arr apps</p>
				</div>
				<div class="rounded-lg border border-surface-3 bg-surface-1 p-4">
					<p class="text-xs text-gray-600 font-mono mb-1">writing about</p>
					<p class="text-sm text-gray-300">Self-hosting, databases, and <a href="/blog">things that probably shouldn't be connected to the internet</a></p>
				</div>
				<div class="rounded-lg border border-surface-3 bg-surface-1 p-4">
					<p class="text-xs text-gray-600 font-mono mb-1">using</p>
					<p class="text-sm text-gray-300">M3 Pro MacBook Pro, VS Code, too many monitors. <a href="/uses">See my full setup &rarr;</a></p>
				</div>
			</div>
		</div>
	</section>

	<!-- Recent Posts -->
	<section class="mx-auto max-w-5xl px-6 py-16">
		<div class="mb-8 flex items-center justify-between">
			<h2 class="text-2xl font-bold text-white">Recent Posts</h2>
			<a href="/blog" class="group text-sm text-coral hover:text-teal transition-colors">
				View all <span class="inline-block transition-transform group-hover:translate-x-1">&rarr;</span>
			</a>
		</div>
		<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
			{posts.map((post, i) => (
				<div class={`scroll-reveal scroll-reveal-delay-${i % 3}`}>
					<BlogCard
						title={post.data.title}
						description={post.data.description}
						date={post.data.date}
						slug={post.data.slug}
						heroImage={post.data.heroImage}
					/>
				</div>
			))}
		</div>
	</section>

	<!-- Fun footer banner — brutalist marquee -->
	<section class="border-t-4 border-lavender overflow-hidden bg-surface-1 py-3">
		<div class="marquee whitespace-nowrap font-mono text-sm text-gray-600">
			<span class="marquee-content">
				DATABASES &bull; SMART HOMES &bull; IoT &bull; DEVREL &bull; OPEN SOURCE &bull; HOMELABS &bull; FILM &bull; CATS &bull; WEIRD PROJECTS &bull; CONFERENCE TALKS &bull; DATABASES &bull; SMART HOMES &bull; IoT &bull; DEVREL &bull; OPEN SOURCE &bull; HOMELABS &bull; FILM &bull; CATS &bull; WEIRD PROJECTS &bull; CONFERENCE TALKS &bull;&nbsp;
			</span>
		</div>
	</section>
</BaseLayout>

<style>
	/* Terminal styles */
	.terminal-body {
		scrollbar-width: thin;
		scrollbar-color: #fdae84 transparent;
	}

	.cursor {
		animation: blink 1s step-end infinite;
		color: #fdae84;
	}

	@keyframes blink {
		0%, 100% { opacity: 1; }
		50% { opacity: 0; }
	}

	.terminal-body :global(.text-coral) {
		color: #fdae84;
	}

	.terminal-body :global(.text-teal) {
		color: #8bcbc8;
	}

	.terminal-body :global(.text-lavender) {
		color: #c4b5fd;
	}

	.terminal-body :global(.text-dim) {
		color: #6b7280;
	}

	.terminal-body :global(.text-white) {
		color: #e5e7eb;
	}

	.terminal-body :global(.text-green) {
		color: #86efac;
	}

	.terminal-body :global(.text-yellow) {
		color: #fde68a;
	}

	/* Scroll reveal */
	.scroll-reveal {
		opacity: 0;
		transform: translateY(20px);
		transition: opacity 0.5s ease, transform 0.5s ease;
	}
	.scroll-reveal.visible {
		opacity: 1;
		transform: translateY(0);
	}
	.scroll-reveal-delay-0 { transition-delay: 0s; }
	.scroll-reveal-delay-1 { transition-delay: 0.1s; }
	.scroll-reveal-delay-2 { transition-delay: 0.2s; }

	/* Marquee */
	.marquee {
		display: flex;
	}
	.marquee-content {
		display: inline-block;
		animation: marquee 20s linear infinite;
	}

	@keyframes marquee {
		from { transform: translateX(0); }
		to { transform: translateX(-50%); }
	}

	/* Button hover effects */
	.btn-primary {
		transition: all 0.3s ease;
		position: relative;
		overflow: hidden;
	}
	.btn-primary:hover {
		transform: translateY(-1px);
		box-shadow: 0 4px 20px rgba(253, 174, 132, 0.3);
	}
	.btn-secondary {
		transition: all 0.3s ease;
	}
	.btn-secondary:hover {
		transform: translateY(-1px);
	}

	/* Reduce motion for accessibility */
	@media (prefers-reduced-motion: reduce) {
		.cursor {
			animation: none !important;
			opacity: 1;
		}
		.scroll-reveal {
			opacity: 1;
			transform: none;
			transition: none;
		}
		.marquee-content {
			animation: none;
		}
		.btn-primary:hover, .btn-secondary:hover {
			transform: none;
		}
	}
</style>

<script>
	const output = document.getElementById('output')!;
	const inputLine = document.getElementById('input-line')!;
	const inputText = document.getElementById('input-text')!;
	const terminal = document.getElementById('terminal')!;
	const hiddenInput = document.getElementById('hidden-input') as HTMLInputElement;

	let currentInput = '';
	let commandHistory: string[] = [];
	let historyIndex = -1;
	let ready = false;

	const pages: Record<string, string> = {
		home: '/',
		blog: '/blog',
		about: '/about',
		work: '/work',
		contact: '/contact',
		uses: '/uses',
		'talk-archive': '/talk-archive',
	};

	function scrollToBottom() {
		terminal.scrollTop = terminal.scrollHeight;
	}

	function appendLine(html: string) {
		const div = document.createElement('div');
		div.innerHTML = html;
		output.appendChild(div);
		scrollToBottom();
	}

	function appendLines(lines: string[]) {
		lines.forEach(line => appendLine(line));
	}

	async function typeLines(lines: string[], delay = 40) {
		for (const line of lines) {
			appendLine(line);
			await sleep(delay);
		}
	}

	function sleep(ms: number): Promise<void> {
		return new Promise(r => setTimeout(r, ms));
	}

	// Simulate typing a command character by character
	async function typeCommand(cmd: string, charDelay = 50) {
		// Show prompt with empty command
		const cmdLine = document.createElement('div');
		cmdLine.className = 'flex items-center';
		const promptSpan = document.createElement('span');
		promptSpan.className = 'text-coral mr-2';
		promptSpan.textContent = 'joe@karlsson ~$';
		const textSpan = document.createElement('span');
		textSpan.className = 'text-white';
		const cursorSpan = document.createElement('span');
		cursorSpan.className = 'cursor';
		cursorSpan.innerHTML = '&#9608;';
		cmdLine.appendChild(promptSpan);
		cmdLine.appendChild(textSpan);
		cmdLine.appendChild(cursorSpan);
		output.appendChild(cmdLine);
		scrollToBottom();

		// Type each character
		for (let i = 0; i < cmd.length; i++) {
			textSpan.textContent = cmd.slice(0, i + 1);
			scrollToBottom();
			await sleep(charDelay);
		}

		await sleep(200);

		// Remove the typing line and replace with static echoed command
		cmdLine.remove();
		appendLine(`<span class="text-coral">joe@karlsson ~$</span> <span class="text-white">${escapeHtml(cmd)}</span>`);
	}

	// --- Commands ---

	function cmdHelp(): string[] {
		return [
			'<span class="text-yellow">Available commands:</span>',
			'',
			'  <span class="text-coral">help</span>         show this message',
			'  <span class="text-coral">ls</span>           list site pages',
			'  <span class="text-coral">cd</span> &lt;page&gt;    navigate to a page',
			'  <span class="text-coral">goto</span> &lt;page&gt;  navigate to a page',
			'  <span class="text-coral">whoami</span>       who is this',
			'  <span class="text-coral">cat about.md</span> about me',
			'  <span class="text-coral">cat readme</span>   read about this site',
			'  <span class="text-coral">uptime</span>       system uptime',
			'  <span class="text-coral">neofetch</span>     system info',
			'  <span class="text-coral">clear</span>        clear terminal',
			'',
		];
	}

	function cmdLs(): string[] {
		const entries = Object.keys(pages).map(p => `  <span class="text-teal">${p}/</span>`);
		return ['<span class="text-dim">drwxr-xr-x  joe  staff</span>', ...entries, ''];
	}

	function cmdCd(args: string): string[] {
		const target = args.trim().replace(/^\//, '').replace(/\/$/, '');
		if (!target) return ['<span class="text-dim">usage: cd &lt;page&gt;</span>', ''];
		if (target === '~' || target === '/') {
			window.location.href = '/';
			return ['Navigating to home...'];
		}
		const url = pages[target];
		if (url) {
			setTimeout(() => { window.location.href = url; }, 400);
			return [`Navigating to /${target}...`];
		}
		return [`<span class="text-coral">cd: no such page: ${target}</span>`, `<span class="text-dim">try 'ls' to see available pages</span>`, ''];
	}

	function cmdWhoami(): string[] {
		return [
			'<span class="text-teal">joe-karlsson</span> — software engineer & massive nerd',
			'',
		];
	}

	function cmdCatAbout(): string[] {
		return [
			'<span class="text-yellow">about.md</span>',
			'',
			'  I\'m a massive nerd who empowers developers to think',
			'  creatively when building applications. Through demos,',
			'  blogs, videos, or whatever else developers need.',
			'',
			'  Currently building data pipelines at <span class="text-white">CloudQuery</span>.',
			'  Previously at <span class="text-white">MongoDB</span> and <span class="text-white">GitHub</span>.',
			'',
			'  <span class="text-dim">TEDx speaker. Homelab hoarder. Film snob.</span>',
			'',
		];
	}

	function cmdCatReadme(): string[] {
		return [
			'<span class="text-yellow">README.md</span>',
			'',
			'  Welcome to joekarlsson.com!',
			'',
			'  This site is where I write about software engineering,',
			'  developer advocacy, homelabs, IoT cat litter boxes,',
			'  and whatever else I\'m nerding out about.',
			'',
			'  Built with Astro. Powered by coffee and stubbornness.',
			'',
			'  <span class="text-dim">Type \'ls\' to see where you can go.</span>',
			'',
		];
	}

	function cmdUptime(): string[] {
		return [
			'  up <span class="text-green">42 days, 3 hours, 17 minutes</span> (since last mass container migration)',
			'  load average: 0.42, 0.69, 1.21',
			'  <span class="text-dim">vibes: immaculate</span>',
			'',
		];
	}

	function cmdNeofetch(): string[] {
		return [
			'',
			'  <span class="text-coral"> ██╗ ██████╗ ███████╗</span>    <span class="text-teal">joe</span>@<span class="text-teal">joekarlsson.com</span>',
			'  <span class="text-coral"> ██║██╔═══██╗██╔════╝</span>    ─────────────────────',
			'  <span class="text-coral"> ██║██║   ██║█████╗  </span>    <span class="text-coral">OS</span>: Astro on Cloudflare',
			'  <span class="text-coral">██  ██║   ██║██╔══╝  </span>    <span class="text-coral">Host</span>: M3 Pro MacBook Pro',
			'  <span class="text-coral">╚█████╔╝██████╔╝███████╗</span>    <span class="text-coral">Kernel</span>: caffeine-6.1.0',
			'  <span class="text-coral"> ╚════╝ ╚═════╝ ╚══════╝</span>    <span class="text-coral">Homelab</span>: Proxmox Cluster x2',
			'                          <span class="text-coral">Shell</span>: bash + vibes',
			'                          <span class="text-coral">GPU</span>: RTX A4000 + Quadro RTX 4000',
			'                          <span class="text-coral">Containers</span>: 40+',
			'                          <span class="text-coral">Work</span>: CloudQuery',
			'                          <span class="text-coral">Cats</span>: 1 (IoT-enabled)',
			'                          <span class="text-coral">Coffee</span>: ████████████░░ 86%',
			'',
			'                          <span style="color:#ff6b6b">██</span><span style="color:#fdae84">██</span><span style="color:#fde68a">██</span><span style="color:#86efac">██</span><span style="color:#8bcbc8">██</span><span style="color:#c4b5fd">██</span><span style="color:#f0abfc">██</span>',
			'',
		];
	}

	function cmdClear(): string[] {
		output.innerHTML = '';
		return [];
	}

	function executeCommand(raw: string) {
		const trimmed = raw.trim();
		if (!trimmed) return;

		// Echo the command
		appendLine(`<span class="text-coral">joe@karlsson ~$</span> <span class="text-white">${escapeHtml(trimmed)}</span>`);

		if (trimmed) commandHistory.unshift(trimmed);
		historyIndex = -1;

		const [cmd, ...rest] = trimmed.split(/\s+/);
		const args = rest.join(' ');

		let result: string[];

		switch (cmd.toLowerCase()) {
			case 'help':
				result = cmdHelp();
				break;
			case 'ls':
				result = cmdLs();
				break;
			case 'cd':
			case 'goto':
				result = cmdCd(args);
				break;
			case 'whoami':
				result = cmdWhoami();
				break;
			case 'cat':
				if (args.toLowerCase() === 'about.md' || args.toLowerCase() === 'about') {
					result = cmdCatAbout();
				} else if (args.toLowerCase() === 'readme' || args.toLowerCase() === 'readme.md') {
					result = cmdCatReadme();
				} else {
					result = [`<span class="text-coral">cat: ${escapeHtml(args) || '???'}: No such file</span>`, ''];
				}
				break;
			case 'uptime':
				result = cmdUptime();
				break;
			case 'neofetch':
				result = cmdNeofetch();
				break;
			case 'clear':
				result = cmdClear();
				break;
			case 'sudo':
				result = ['<span class="text-coral">nice try.</span>', ''];
				break;
			case 'exit':
				result = ['<span class="text-dim">You\'re already home.</span>', ''];
				break;
			case 'rm':
				result = ['<span class="text-coral">absolutely not.</span>', ''];
				break;
			default:
				result = [`<span class="text-dim">${escapeHtml(cmd)}: command not found. try 'help'</span>`, ''];
		}

		appendLines(result);
	}

	function escapeHtml(str: string): string {
		const div = document.createElement('div');
		div.textContent = str;
		return div.innerHTML;
	}

	function updateInputDisplay() {
		inputText.textContent = currentInput;
		scrollToBottom();
	}

	// --- Keyboard handler ---
	function focusInput() {
		hiddenInput.focus();
	}

	hiddenInput.addEventListener('keydown', (e: KeyboardEvent) => {
		if (!ready) return;

		if (e.key === 'Enter') {
			e.preventDefault();
			const cmd = currentInput;
			currentInput = '';
			hiddenInput.value = '';
			updateInputDisplay();
			inputLine.style.display = 'none';
			executeCommand(cmd);
			inputLine.style.display = 'flex';
			updateInputDisplay();
		} else if (e.key === 'ArrowUp') {
			e.preventDefault();
			if (commandHistory.length > 0 && historyIndex < commandHistory.length - 1) {
				historyIndex++;
				currentInput = commandHistory[historyIndex];
				hiddenInput.value = currentInput;
				updateInputDisplay();
			}
		} else if (e.key === 'ArrowDown') {
			e.preventDefault();
			if (historyIndex > 0) {
				historyIndex--;
				currentInput = commandHistory[historyIndex];
			} else {
				historyIndex = -1;
				currentInput = '';
			}
			hiddenInput.value = currentInput;
			updateInputDisplay();
		} else if (e.key === 'Tab') {
			e.preventDefault();
			const partial = currentInput.replace(/^(cd|goto)\s+/, '');
			const prefix = currentInput.replace(partial, '');
			const matches = Object.keys(pages).filter(p => p.startsWith(partial));
			if (matches.length === 1) {
				currentInput = prefix + matches[0];
				hiddenInput.value = currentInput;
				updateInputDisplay();
			}
		} else if (e.key === 'l' && e.ctrlKey) {
			e.preventDefault();
			cmdClear();
		}
	});

	hiddenInput.addEventListener('input', () => {
		if (!ready) return;
		currentInput = hiddenInput.value;
		updateInputDisplay();
	});

	terminal.addEventListener('click', () => {
		focusInput();
	});

	// --- Boot sequence ---
	async function boot() {
		// Check for reduced motion preference
		const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		if (prefersReducedMotion) {
			// Skip animations — show final state immediately
			appendLines(cmdNeofetch());
			appendLine(`<span class="text-coral">joe@karlsson ~$</span> <span class="text-white">cat about.md</span>`);
			appendLines(cmdCatAbout());
			appendLine(`<span class="text-coral">joe@karlsson ~$</span> <span class="text-white">ls</span>`);
			appendLines(cmdLs());
			appendLines([
				'<span class="text-dim">  Type \'help\' for commands, or \'cd &lt;page&gt;\' to navigate.</span>',
				'',
			]);
			inputLine.style.display = 'flex';
			ready = true;
			focusInput();
			return;
		}

		// Boot lines
		const bootLines = [
			'<span class="text-dim">[    0.000000] joekarlsson.com kernel loading...</span>',
			'<span class="text-dim">[    0.042069] Initializing vibes subsystem</span>',
			'<span class="text-dim">[    0.133700] Mounting /dev/pages ... <span class="text-green">OK</span></span>',
		];

		await typeLines(bootLines, 100);
		await sleep(300);

		// neofetch
		await typeCommand('neofetch', 60);
		appendLines(cmdNeofetch());
		await sleep(600);

		// cat about.md
		await typeCommand('cat about.md', 50);
		appendLines(cmdCatAbout());
		await sleep(600);

		// ls
		await typeCommand('ls', 80);
		appendLines(cmdLs());
		await sleep(300);

		appendLines([
			'<span class="text-dim">  Type \'help\' for commands, or \'cd &lt;page&gt;\' to navigate.</span>',
			'',
		]);

		inputLine.style.display = 'flex';
		ready = true;
		focusInput();
	}

	boot();

	// Scroll reveal with Intersection Observer
	const observer = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					entry.target.classList.add('visible');
					observer.unobserve(entry.target);
				}
			});
		},
		{ threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
	);

	document.querySelectorAll('.scroll-reveal').forEach((el) => {
		observer.observe(el);
	});
</script>
