---
import { getCollection } from 'astro:content';
import BlogCard from '../components/BlogCard.astro';
import RightNow from '../components/RightNow.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION, SOCIAL_LINKS } from '../consts';
import { projects } from '../data/projects';

const homepageProjects = projects.filter((p) =>
	['IoT Kitty Litter Box', 'Bechdel.io', 'React Spotify Player', 'Wave Jump'].includes(p.title),
);

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 6);

const taglines = [
	'Built an IoT cat toilet. Gave a conference talk about it.',
	'Mass-assigning GPU transcoding jobs at 2am on a Tuesday.',
	'Running 40+ containers because "it\'ll be quick to set up."',
	'TEDx speaker. Homelab hoarder. Film snob.',
	"Teaching computers to do things they probably shouldn't.",
	'TEDx Speaker - talked about the art of computer science.',
];
---

<BaseLayout title="Joe Karlsson - Developer Advocate & Massive Nerd" description={SITE_DESCRIPTION}>
	<h1 class="sr-only">Joe Karlsson - Software Engineer & Developer Advocate</h1>
	<!-- Hero: Two terminal windows side by side -->
	<section id="hero-section" class="border-b-4 border-coral relative overflow-hidden">
		<div id="hero-content" class="flex flex-col lg:flex-row">
			<!-- Left terminal: interactive -->
			<div class="flex-1 lg:border-r border-surface-3 flex flex-col">
				<div class="flex items-center gap-2 px-4 py-2 bg-surface-1 border-b border-surface-3">
					<span class="w-3 h-3 rounded-full bg-red-500/80"></span>
					<span class="w-3 h-3 rounded-full bg-yellow-500/80"></span>
					<span class="w-3 h-3 rounded-full bg-green-500/80"></span>
					<span class="ml-2 text-xs text-gray-400 font-mono">joe@karlsson - bash</span>
				</div>
				<div
					id="terminal"
					class="terminal-body bg-surface-0 px-4 md:px-8 py-4 md:py-6 font-mono text-sm leading-relaxed h-[18rem] md:h-[22rem] lg:h-[28rem] overflow-y-auto cursor-text relative"
					tabindex="0"
					role="application"
					aria-label="Interactive terminal. Type help for available commands."
				>
					<div id="output"></div>
					<div id="input-line" class="flex items-center" style="display:none;">
						<span class="prompt text-coral mr-2">~$</span>
						<span id="input-text" class="text-gray-200"></span><span id="cursor" class="cursor"
							>&#9608;</span
						>
					</div>
					<!-- Arrow-navigable menu -->
					<nav id="nav-menu" class="mt-3" style="display:none;" aria-label="Site navigation">
						<div id="nav-items"></div>
					</nav>
					<label for="hidden-input" class="sr-only">Terminal command input</label>
					<input
						id="hidden-input"
						type="text"
						class="absolute opacity-0 w-0 h-0 pointer-events-none"
						autocomplete="off"
						autocorrect="off"
						autocapitalize="off"
						spellcheck="false"
					/>
				</div>
				<div class="bg-surface-1 border-t border-surface-3 px-5 md:px-8 py-2">
					<p
						class="font-mono text-xs text-gray-300 md:text-gray-400 transition-opacity duration-300"
						id="rotating-tagline"
					>
						{taglines[0]}
					</p>
				</div>
			</div>

			<!-- Right terminal: about me (hidden on mobile) -->
			<div class="hidden lg:flex lg:w-[26rem] xl:w-[30rem] flex-col border-surface-3">
				<div class="flex items-center gap-2 px-4 py-2 bg-surface-1 border-b border-surface-3">
					<span class="w-3 h-3 rounded-full bg-red-500/80"></span>
					<span class="w-3 h-3 rounded-full bg-yellow-500/80"></span>
					<span class="w-3 h-3 rounded-full bg-green-500/80"></span>
					<span class="ml-2 text-xs text-gray-400 font-mono">cat about.md</span>
				</div>
				<div
					class="bg-surface-0 px-5 md:px-8 py-4 font-mono text-sm leading-relaxed h-[22rem] lg:h-[28rem] overflow-hidden"
				>
					<p class="text-yellow mb-3">## about.md</p>

					<p class="text-coral text-lg font-bold mb-1">Joe Karlsson</p>
					<p class="text-teal text-xs mb-3">he/they · software engineer · dev advocate</p>

					<p class="text-gray-300 mb-2">
						Hey, I'm Joe. I help developers build cool stuff - through demos, blog posts, talks,
						videos, whatever works.
					</p>
					<p class="text-gray-300 mb-2">
						Currently at <span class="text-white">CloudQuery</span>. Outside of work I run a
						<span class="text-teal">40+ container homelab</span>, watch way too many movies, and
						build things that probably shouldn't be connected to the internet.
					</p>
					<p class="text-gray-300 mb-3">
						I once built an IoT cat toilet and gave a conference talk about it. Also a
						<span class="text-white">TEDx speaker</span>. I contain multitudes.
					</p>

					<div class="border-t border-surface-3 pt-3 mt-3">
						<p class="text-dim text-xs mb-2">$ neofetch --short</p>
						<div class="grid grid-cols-2 gap-x-4 gap-y-1 text-xs">
							<p>
								<span class="text-coral">Containers</span>: <span class="text-gray-300">40+</span>
							</p>
							<p>
								<span class="text-coral">Homelab</span>: <span class="text-gray-300"
									>Proxmox x2</span
								>
							</p>
							<p>
								<span class="text-coral">Daily</span>: <span class="text-gray-300">M3 Pro MBP</span>
							</p>
							<p>
								<span class="text-coral">Cats</span>: <span class="text-gray-300">1 (IoT)</span>
							</p>
						</div>
					</div>

					</div>
			</div>
		</div>
	</section>

	<!-- Right Now -->
	<section class="border-b-4 border-teal">
		<div class="mx-auto max-w-5xl px-6 py-14">
			<h2 class="mb-6 text-lg font-bold text-white">
				<span class="text-coral font-mono text-sm" aria-hidden="true">~$</span> cat now.md
			</h2>
			<RightNow />
		</div>
	</section>

	<!-- Featured Projects -->
	<section class="border-b border-surface-3">
		<div class="mx-auto max-w-5xl px-6 py-14">
			<div class="mb-6 flex items-center justify-between">
				<h2 class="text-lg font-bold text-white">
					<span class="text-coral font-mono text-sm" aria-hidden="true">~$</span> ls projects/
				</h2>
				<a href="/work" class="group text-sm text-coral hover:text-teal transition-colors">
					See all <span class="inline-block transition-transform group-hover:translate-x-1"
						>&rarr;</span
					>
				</a>
			</div>
			<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
				{
					homepageProjects.map((project) => {
						const url = project.sourceUrl || project.blogUrl || '#';
						const isExternal = url.startsWith('http');
						return (
							<a
								href={url}
								target={isExternal ? '_blank' : undefined}
								rel={isExternal ? 'noopener noreferrer' : undefined}
								class="group block rounded-lg border border-surface-3 bg-surface-1 p-4 no-underline transition-all duration-300 hover:-translate-y-0.5 hover:border-coral/30"
							>
								<img
									src={project.image}
									alt={project.imageAlt}
									class="mb-3 h-28 w-full rounded-md object-cover transition-transform duration-300 group-hover:scale-105"
									width="600"
									height="112"
									loading="lazy"
								/>
								<p class="font-semibold text-sm text-white group-hover:text-coral">
									{project.title}
								</p>
								<div class="mt-1 flex flex-wrap gap-1">
									{project.tech.slice(0, 3).map((t) => (
										<span class="rounded-full bg-surface-3 px-2 py-0.5 font-mono text-[10px] text-gray-400">
											{t}
										</span>
									))}
								</div>
							</a>
						);
					})
				}
			</div>
		</div>
	</section>

	<!-- Recent Posts -->
	<section class="mx-auto max-w-5xl px-6 py-16">
		<div class="mb-8 flex items-center justify-between">
			<h2 class="text-lg font-bold text-white">
				<span class="text-coral font-mono text-sm" aria-hidden="true">~$</span> ls posts/ --recent
			</h2>
			<a href="/blog" class="group text-sm text-coral hover:text-teal transition-colors">
				View all <span class="inline-block transition-transform group-hover:translate-x-1"
					>&rarr;</span
				>
			</a>
		</div>
		<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
			{
				posts.map((post, i) => (
					<div class={`scroll-reveal scroll-reveal-delay-${i % 3}`}>
						<BlogCard
							title={post.data.title}
							description={post.data.description}
							date={post.data.date}
							slug={post.data.slug}
							heroImage={post.data.heroImage}
						/>
					</div>
				))
			}
		</div>
	</section>

	<!-- Fun footer banner - brutalist marquee -->
	<section class="border-t-4 border-lavender overflow-hidden bg-surface-1 py-3">
		<div class="marquee whitespace-nowrap font-mono text-sm text-gray-400">
			<span class="marquee-content" aria-hidden="false">
				DATABASES &bull; SMART HOMES &bull; IoT &bull; DEVREL &bull; OPEN SOURCE &bull; HOMELABS
				&bull; FILM &bull; CATS &bull; WEIRD PROJECTS &bull; CONFERENCE TALKS &bull;&nbsp;
			</span>
			<span class="marquee-content" aria-hidden="true">
				DATABASES &bull; SMART HOMES &bull; IoT &bull; DEVREL &bull; OPEN SOURCE &bull; HOMELABS
				&bull; FILM &bull; CATS &bull; WEIRD PROJECTS &bull; CONFERENCE TALKS &bull;&nbsp;
			</span>
		</div>
	</section>
</BaseLayout>

<style>
	.terminal-body {
		scrollbar-width: thin;
		scrollbar-color: #fdae84 transparent;
	}

	.cursor {
		animation: blink 1s step-end infinite;
		color: #fdae84;
	}

	@keyframes blink {
		0%,
		100% {
			opacity: 1;
		}
		50% {
			opacity: 0;
		}
	}

	.terminal-body :global(.text-coral) {
		color: #fdae84;
	}
	.terminal-body :global(.text-teal) {
		color: #8bcbc8;
	}
	.terminal-body :global(.text-lavender) {
		color: #c4b5fd;
	}
	.terminal-body :global(.text-dim) {
		color: #b0b8c4;
	}
	.terminal-body :global(.text-white) {
		color: #e5e7eb;
	}
	.terminal-body :global(.text-green) {
		color: #86efac;
	}
	.terminal-body :global(.text-yellow) {
		color: #fde68a;
	}

	/* CLI selector style — :global because items are JS-generated */
	.terminal-body :global(.nav-item) {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.8125rem;
		padding: 6px 8px;
		cursor: pointer;
		white-space: nowrap;
		border-radius: 4px;
		border: 1px solid rgba(253, 174, 132, 0.2);
		background: rgba(253, 174, 132, 0.05);
		margin-bottom: 4px;
	}
	.terminal-body :global(.nav-item:active) {
		background: rgba(253, 174, 132, 0.18);
		border-color: rgba(253, 174, 132, 0.4);
	}
	@media (min-width: 768px) {
		.terminal-body :global(.nav-item) {
			font-size: 0.875rem;
			padding: 2px 0;
			border-radius: 0;
			border: none;
			background: none;
			margin-bottom: 0;
		}
		.terminal-body :global(.nav-item:hover) {
			background: rgba(253, 174, 132, 0.08);
		}
		.terminal-body :global(.nav-item:active) {
			background: rgba(253, 174, 132, 0.08);
			border-color: transparent;
		}
	}
	.terminal-body :global(.nav-item-selected) {
		color: #fdae84;
		border-color: rgba(253, 174, 132, 0.35);
		background: rgba(253, 174, 132, 0.1);
	}
	@media (min-width: 768px) {
		.terminal-body :global(.nav-item-selected) {
			border-color: transparent;
			background: none;
		}
	}
	.terminal-body :global(.nav-item-unselected) {
		color: #c9cdd3;
	}
	.terminal-body :global(.nav-item-unselected .nav-label) {
		color: #c9cdd3;
	}
	.terminal-body :global(.nav-item-selected .nav-label) {
		color: #e5e7eb;
	}

	.scroll-reveal {
		opacity: 0;
		transform: translateY(20px);
		transition:
			opacity 0.5s ease,
			transform 0.5s ease;
	}
	.scroll-reveal.visible {
		opacity: 1;
		transform: translateY(0);
	}
	.scroll-reveal-delay-0 {
		transition-delay: 0s;
	}
	.scroll-reveal-delay-1 {
		transition-delay: 0.1s;
	}
	.scroll-reveal-delay-2 {
		transition-delay: 0.2s;
	}

	.marquee {
		display: flex;
		overflow: hidden;
	}
	.marquee-content {
		flex-shrink: 0;
		display: inline-block;
		animation: marquee 25s linear infinite;
	}
	@keyframes marquee {
		from {
			transform: translateX(0);
		}
		to {
			transform: translateX(-100%);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.cursor {
			animation: none !important;
			opacity: 1;
		}
		.scroll-reveal {
			opacity: 1;
			transform: none;
			transition: none;
		}
		.marquee-content {
			animation: none;
		}
	}
</style>

<script>
	const output = document.getElementById('output')!;
	const inputLine = document.getElementById('input-line')!;
	const inputText = document.getElementById('input-text')!;
	const terminal = document.getElementById('terminal')!;
	const hiddenInput = document.getElementById('hidden-input') as HTMLInputElement;

	let currentInput = '';
	let commandHistory: string[] = [];
	let historyIndex = -1;
	let ready = false;

	// CLI selector menu
	const navMenu = document.getElementById('nav-menu')!;
	const navItems = document.getElementById('nav-items')!;
	let menuActive = false;
	let menuIndex = 0;
	let currentMenuLevel: 'main' | 'pages' = 'main';

	type MenuOption = {
		label: string;
		desc: string;
		action: string;
		href?: string;
	};

	const mainMenu: MenuOption[] = [
		{ label: 'cat about.md', desc: 'who am I', action: 'cat-about' },
		{ label: 'cat work.md', desc: "things I've built", action: 'cat-work' },
		{ label: 'neofetch', desc: 'system info', action: 'neofetch' },
		{ label: 'cd', desc: 'browse pages', action: 'browse-pages' },
		{ label: 'whoami', desc: '', action: 'whoami' },
		{ label: 'hack', desc: '???', action: 'easter-egg' },
	];

	const pagesMenu: MenuOption[] = [
		{ label: 'blog/', desc: 'databases, homelabs, dev tools', action: 'nav', href: '/blog' },
		{ label: 'about/', desc: 'the longer version', action: 'nav', href: '/about' },
		{ label: 'work/', desc: "things I've built", action: 'nav', href: '/work' },
		{ label: 'uses/', desc: 'gear & homelab', action: 'nav', href: '/uses' },
		{ label: 'contact/', desc: 'say hi', action: 'nav', href: '/contact' },
		{ label: '../', desc: 'back', action: 'back' },
	];

	function activeMenu(): MenuOption[] {
		return currentMenuLevel === 'pages' ? pagesMenu : mainMenu;
	}

	function renderMenu() {
		const menu = activeMenu();
		const header =
			currentMenuLevel === 'pages'
				? '<div class="text-dim mb-1">  <span class="text-teal">~/pages</span> - where do you want to go?</div>'
				: '';
		navItems.innerHTML =
			header +
			menu
				.map((opt, i) => {
					const sel = i === menuIndex;
					const arrow = sel ? '<span class="text-coral">❯</span>' : ' ';
					const desc = opt.desc ? ` <span class="text-dim">${opt.desc}</span>` : '';
					const labelClass = currentMenuLevel === 'pages' ? 'text-teal' : '';
					return `<div class="nav-item ${sel ? 'nav-item-selected' : 'nav-item-unselected'}" data-index="${i}">  ${arrow} <span class="nav-label ${sel ? labelClass : ''}">${opt.label}</span>${desc}</div>`;
				})
				.join('');

		navItems.querySelectorAll('.nav-item').forEach((el) => {
			el.addEventListener('click', () => {
				menuIndex = parseInt((el as HTMLElement).dataset.index || '0');
				renderMenu();
				selectMenuItem();
			});
		});
	}

	function selectMenuItem() {
		const menu = activeMenu();
		const opt = menu[menuIndex];

		if (opt.action === 'back') {
			currentMenuLevel = 'main';
			menuIndex = 0;
			renderMenu();
			scrollToBottom();
			return;
		}

		if (opt.action === 'nav' && opt.href) {
			appendLine(
				`<span class="text-coral">~$</span> <span class="text-white">cd ${opt.label.replace('/', '')}</span>`,
			);
			appendLine(`Navigating to ${opt.href}...`);
			setTimeout(() => {
				window.location.href = opt.href!;
			}, 400);
			return;
		}

		if (opt.action === 'browse-pages') {
			appendLine(`<span class="text-coral">~$</span> <span class="text-white">cd</span>`);
			appendLines(cmdLs());
			currentMenuLevel = 'pages';
			menuIndex = 0;
			renderMenu();
			scrollToBottom();
			focusInput();
			return;
		}

		hideMenu();
		appendLine(`<span class="text-coral">~$</span> <span class="text-white">${opt.label}</span>`);

		switch (opt.action) {
			case 'cat-about':
				appendLines(cmdCatAbout());
				showMenu();
				break;
			case 'cat-work':
				appendLines(cmdCatWork());
				showMenu();
				break;
			case 'neofetch':
				appendLines(cmdNeofetch());
				showMenu();
				break;
			case 'whoami':
				appendLines(cmdWhoami());
				showMenu();
				break;
			case 'easter-egg':
				runMatrixRain();
				break;
		}
		focusInput();
	}

	function showMenu() {
		navMenu.style.display = 'block';
		menuActive = true;
		currentMenuLevel = 'main';
		menuIndex = 0;
		renderMenu();
		scrollToBottom();
	}

	function hideMenu() {
		navMenu.style.display = 'none';
		menuActive = false;
	}

	const suggestions = [
		'help',
		'neofetch',
		'cat about.md',
		'ls',
		'whoami',
		'hack',
		'cat readme',
		'uptime',
	];
	let suggestionIndex = -1;

	const pages: Record<string, string> = {
		home: '/',
		blog: '/blog',
		about: '/about',
		work: '/work',
		contact: '/contact',
		uses: '/uses',
		'talk-archive': '/talk-archive',
	};

	function scrollToBottom() {
		terminal.scrollTop = terminal.scrollHeight;
	}

	function appendLine(html: string) {
		const div = document.createElement('div');
		div.innerHTML = html;
		output.appendChild(div);
		scrollToBottom();
	}

	function appendLines(lines: string[]) {
		lines.forEach((line) => appendLine(line));
	}

	async function typeLines(lines: string[], delay = 40) {
		for (const line of lines) {
			appendLine(line);
			await sleep(delay);
		}
	}

	function sleep(ms: number): Promise<void> {
		return new Promise((r) => setTimeout(r, ms));
	}

	async function typeCommand(cmd: string, charDelay = 50) {
		const cmdLine = document.createElement('div');
		cmdLine.className = 'flex items-center';
		const promptSpan = document.createElement('span');
		promptSpan.className = 'text-coral mr-2';
		promptSpan.textContent = '~$';
		const textSpan = document.createElement('span');
		textSpan.className = 'text-white';
		const cursorSpan = document.createElement('span');
		cursorSpan.className = 'cursor';
		cursorSpan.innerHTML = '&#9608;';
		cmdLine.appendChild(promptSpan);
		cmdLine.appendChild(textSpan);
		cmdLine.appendChild(cursorSpan);
		output.appendChild(cmdLine);
		scrollToBottom();

		for (let i = 0; i < cmd.length; i++) {
			textSpan.textContent = cmd.slice(0, i + 1);
			scrollToBottom();
			await sleep(charDelay);
		}

		await sleep(200);
		cmdLine.remove();
		appendLine(
			`<span class="text-coral">~$</span> <span class="text-white">${escapeHtml(cmd)}</span>`,
		);
	}

	// --- Matrix rain easter egg (full hero overlay) ---
	async function runMatrixRain() {
		ready = false;
		inputLine.style.display = 'none';
		navMenu.style.display = 'none';

		const heroSection = document.getElementById('hero-section')!;
		const heroContent = document.getElementById('hero-content')!;

		// Create overlay that covers the entire hero
		const overlay = document.createElement('div');
		overlay.style.cssText =
			'position:absolute;top:0;left:0;right:0;bottom:0;z-index:50;background:#0a0a0f;display:flex;align-items:center;justify-content:center;';
		heroSection.appendChild(overlay);

		const rainCanvas = document.createElement('div');
		rainCanvas.style.cssText =
			'position:absolute;top:0;left:0;right:0;bottom:0;overflow:hidden;font-family:monospace;padding:8px;';
		overlay.appendChild(rainCanvas);

		const msgDiv = document.createElement('div');
		msgDiv.style.cssText =
			'position:relative;z-index:10;text-align:center;opacity:0;transition:opacity 0.5s;';
		overlay.appendChild(msgDiv);

		const chars = 'ジョーカールソン01アイオーティー猫ホームラブ';
		const charW = 10;
		const lineH = 14;
		const cols = Math.floor(heroSection.clientWidth / charW);
		const rows = Math.floor(heroSection.clientHeight / lineH);
		const grid: string[][] = Array.from({ length: rows }, () => Array(cols).fill(' '));
		const drops: number[] = Array(cols)
			.fill(0)
			.map(() => Math.floor(Math.random() * -rows));

		const rainPre = document.createElement('pre');
		rainPre.style.cssText = `font-size:${charW + 2}px;line-height:${lineH}px;margin:0;white-space:pre;`;
		rainCanvas.appendChild(rainPre);

		for (let frame = 0; frame < 80; frame++) {
			for (let c = 0; c < cols; c++) {
				drops[c]++;
				if (drops[c] >= 0 && drops[c] < rows) {
					grid[drops[c]][c] = chars[Math.floor(Math.random() * chars.length)];
				}
				if (drops[c] > rows + Math.floor(Math.random() * rows)) {
					drops[c] = Math.floor(Math.random() * -6);
				}
				if (drops[c] >= 3 && drops[c] - 3 < rows) {
					grid[drops[c] - 3][c] =
						Math.random() > 0.6 ? chars[Math.floor(Math.random() * chars.length)] : ' ';
				}
			}

			let html = '';
			for (let r = 0; r < rows; r++) {
				for (let c = 0; c < cols; c++) {
					const ch = grid[r][c];
					if (ch !== ' ') {
						const isHead = drops[c] === r;
						const color = isHead ? '#fff' : Math.random() > 0.5 ? '#86efac' : '#22c55e';
						html += `<span style="color:${color}">${ch}</span>`;
					} else {
						html += ' ';
					}
				}
				html += '\n';
			}
			rainPre.innerHTML = html;
			await sleep(50);
		}

		// Show HACK THE PLANET! centered over the rain
		msgDiv.innerHTML =
			'<span style="color:#86efac;font-size:2.5em;font-weight:bold;font-family:monospace;text-shadow:0 0 20px #22c55e,0 0 40px #22c55e;">HACK THE PLANET!</span>';
		msgDiv.style.opacity = '1';
		rainPre.style.opacity = '0.3';

		await sleep(2500);

		// Fade out overlay
		overlay.style.transition = 'opacity 0.4s';
		overlay.style.opacity = '0';
		await sleep(400);
		overlay.remove();

		// Restore terminal
		inputLine.style.display = 'flex';
		ready = true;
		showMenu();
		focusInput();
	}

	// --- Commands ---

	function cmdHelp(): string[] {
