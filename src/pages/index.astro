	function cmdClear(): string[] {
		output.innerHTML = '';
		return [];
	}

	function executeCommand(raw: string) {
		const trimmed = raw.trim();
		if (!trimmed) return;

		appendLine(
			`<span class="text-coral">~$</span> <span class="text-white">${escapeHtml(trimmed)}</span>`,
		);

		if (trimmed) commandHistory.unshift(trimmed);
		historyIndex = -1;

		const [cmd, ...rest] = trimmed.split(/\s+/);
		const args = rest.join(' ');

		let result: string[];

		switch (cmd.toLowerCase()) {
			case 'help':
				result = cmdHelp();
				break;
			case 'ls':
				result = cmdLs();
				break;
			case 'cd':
			case 'goto':
				result = cmdCd(args);
				break;
			case 'whoami':
				result = cmdWhoami();
				break;
			case 'cat':
				if (args.toLowerCase() === 'about.md' || args.toLowerCase() === 'about') {
					result = cmdCatAbout();
				} else if (args.toLowerCase() === 'work.md' || args.toLowerCase() === 'work') {
					result = cmdCatWork();
				} else if (args.toLowerCase() === 'readme' || args.toLowerCase() === 'readme.md') {
					result = cmdCatReadme();
				} else if (args.toLowerCase() === 'cat' || args.toLowerCase() === 'cat.md') {
					result = [
						'',
						'    <span class="text-coral">/\\_/\\</span>',
						'   <span class="text-coral">( o.o )</span>',
						'    <span class="text-coral">> ^ <</span>',
						'',
						'  <span class="text-dim">meow. (IoT-enabled)</span>',
						'',
					];
				} else {
					result = [
						`<span class="text-coral">cat: ${escapeHtml(args) || '???'}: No such file</span>`,
						'',
					];
				}
				break;
			case 'uptime':
				result = cmdUptime();
				break;
			case 'neofetch':
				result = cmdNeofetch();
				break;
			case 'clear':
				result = cmdClear();
				break;
			case 'sudo':
				result = ['<span class="text-coral">nice try.</span>', ''];
				break;
			case 'exit':
				result = ['<span class="text-dim">You\'re already home.</span>', ''];
				break;
			case 'rm':
				result = ['<span class="text-coral">absolutely not.</span>', ''];
				break;
			case 'matrix':
			case 'hack':
				runMatrixRain();
				return;
			default:
				result = [
					`<span class="text-dim">${escapeHtml(cmd)}: command not found. try 'help'</span>`,
					'',
				];
		}

		appendLines(result);
	}

	function escapeHtml(str: string): string {
		const div = document.createElement('div');
		div.textContent = str;
		return div.innerHTML;
	}

	function updateInputDisplay() {
		inputText.textContent = currentInput;
		scrollToBottom();
	}

	function focusInput() {
		hiddenInput.focus();
	}

	hiddenInput.addEventListener('keydown', (e: KeyboardEvent) => {
		if (!ready) return;

		if (menuActive) {
			if (e.key === 'ArrowUp') {
				e.preventDefault();
				menuIndex = (menuIndex - 1 + activeMenu().length) % activeMenu().length;
				renderMenu();
				scrollToBottom();
				return;
			} else if (e.key === 'ArrowDown') {
				e.preventDefault();
				menuIndex = (menuIndex + 1) % activeMenu().length;
				renderMenu();
				scrollToBottom();
				return;
			} else if (e.key === 'Escape' && currentMenuLevel === 'pages') {
				e.preventDefault();
				currentMenuLevel = 'main';
				menuIndex = 0;
				renderMenu();
				scrollToBottom();
				return;
			} else if (e.key === 'Enter') {
				e.preventDefault();
				selectMenuItem();
				return;
			} else {
				hideMenu();
			}
		}

		if (e.key === 'Enter') {
			e.preventDefault();
			const cmd = currentInput;
			currentInput = '';
			hiddenInput.value = '';
			updateInputDisplay();
			inputLine.style.display = 'none';
			hideMenu();
			executeCommand(cmd);
			inputLine.style.display = 'flex';
			showMenu();
			updateInputDisplay();
		} else if (e.key === 'ArrowUp') {
			e.preventDefault();
			if (commandHistory.length > 0) {
				if (historyIndex < commandHistory.length - 1) {
					historyIndex++;
					currentInput = commandHistory[historyIndex];
					hiddenInput.value = currentInput;
					updateInputDisplay();
				}
			} else {
				if (suggestionIndex < suggestions.length - 1) {
					suggestionIndex++;
					currentInput = suggestions[suggestionIndex];
					hiddenInput.value = currentInput;
					updateInputDisplay();
				}
			}
		} else if (e.key === 'ArrowDown') {
			e.preventDefault();
			if (commandHistory.length > 0) {
				if (historyIndex > 0) {
					historyIndex--;
					currentInput = commandHistory[historyIndex];
				} else {
					historyIndex = -1;
					currentInput = '';
				}
			} else {
				if (suggestionIndex > 0) {
					suggestionIndex--;
					currentInput = suggestions[suggestionIndex];
				} else {
					suggestionIndex = -1;
					currentInput = '';
				}
			}
			hiddenInput.value = currentInput;
			updateInputDisplay();
		} else if (e.key === 'Tab') {
			e.preventDefault();
			const partial = currentInput.replace(/^(cd|goto)\s+/, '');
			const prefix = currentInput.replace(partial, '');
			const matches = Object.keys(pages).filter((p) => p.startsWith(partial));
			if (matches.length === 1) {
				currentInput = prefix + matches[0];
				hiddenInput.value = currentInput;
				updateInputDisplay();
			}
		} else if (e.key === 'l' && e.ctrlKey) {
			e.preventDefault();
			cmdClear();
		}
	});

	hiddenInput.addEventListener('input', () => {
		if (!ready) return;
		currentInput = hiddenInput.value;
		updateInputDisplay();
	});

	terminal.addEventListener('click', () => {
		focusInput();
	});

	// --- Boot sequence ---
	async function boot() {
		const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		const isMobile = window.innerWidth < 768;

		if (prefersReducedMotion || isMobile) {
			appendLine('<span class="text-dim">Welcome to joekarlsson.com</span>');
			appendLine('');
			inputLine.style.display = 'flex';
			showMenu();
			ready = true;
			if (!isMobile) focusInput();
			return;
		}

		appendLine('<span class="text-dim">[  0.000] joekarlsson.com kernel loading...</span>');
		await sleep(80);
		appendLine(
			'<span class="text-dim">[  0.042] Mounting /dev/pages ... <span class="text-green">OK</span></span>',
		);
		await sleep(150);
		appendLine('<span class="text-dim">[  0.069] Welcome.</span>');
		await sleep(200);
		appendLine('');

		inputLine.style.display = 'flex';
		showMenu();
		ready = true;
		focusInput();
	}

	boot();

	// --- Rotating tagline ---
	const taglineEl = document.getElementById('rotating-tagline');
	const taglines = [
		'Built an IoT cat toilet. Gave a conference talk about it.',
		'Mass-assigning GPU transcoding jobs at 2am on a Tuesday.',
		'Running 40+ containers because "it\'ll be quick to set up."',
		'TEDx speaker. Homelab hoarder. Film snob.',
		"Teaching computers to do things they probably shouldn't.",
		'TEDx Speaker - talked about the art of computer science.',
	];
	if (taglineEl) {
		let ti = 0;
		taglineEl.style.transition = 'opacity 0.3s ease';
		setInterval(() => {
			ti = (ti + 1) % taglines.length;
			taglineEl.style.opacity = '0';
			setTimeout(() => {
				taglineEl.textContent = taglines[ti];
				taglineEl.style.opacity = '1';
			}, 300);
		}, 4000);
	}

	// Scroll reveal
	const observer = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					entry.target.classList.add('visible');
					observer.unobserve(entry.target);
				}
			});
		},
		{ threshold: 0.1, rootMargin: '0px 0px -40px 0px' },
	);
	document.querySelectorAll('.scroll-reveal').forEach((el) => observer.observe(el));
</script>
