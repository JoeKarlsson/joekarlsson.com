---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SOCIAL_LINKS } from '../consts';
---

<BaseLayout title="About | Joe Karlsson" description="Software Engineer & Developer Advocate. TEDx Speaker, film buff, homelab enthusiast, and massive nerd.">
	<div class="mx-auto max-w-3xl px-4 py-8">
		<div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:gap-8">
			<img
				src="/images/joe-profile.jpg"
				alt="Joe Karlsson"
				class="mb-4 sm:mb-0 w-32 h-32 sm:w-40 sm:h-40 rounded-lg border-4 border-coral object-cover"
				width="160"
				height="160"
				loading="eager"
			/>
			<div>
				<h1 class="mb-2 text-4xl font-bold md:text-5xl">
					<span class="text-coral">About Joe Karlsson</span>
				</h1>
				<p class="text-xl text-teal">He/They</p>
			</div>
		</div>

		<div class="prose">
			<p class="text-lg">
				I'm a Software Engineer turned Developer Advocate (and massive nerd).
				I empower developers to think creatively when building applications,
				through <a href="/work">demos</a>, <a href="/blog">blogs</a>,
				<a href="/talk-archive">videos</a>, or whatever else developers need.
			</p>

			<p>
				My career has taken me from teaching at one of the most highly-rated software
				development boot camps on Earth, to architecting and building one of the largest
				eCommerce websites in North America at Best Buy, to building out developer
				communities for MongoDB, SingleStore, and CloudQuery.
				I'm also a <a href="https://www.ted.com/talks/joe_karlsson_the_art_of_computer_science" target="_blank" rel="noopener">TEDx Speaker</a>,
				film buff, and avid homelab enthusiast.
			</p>
		</div>

		<!-- What I'm Into -->
		<div class="my-10 grid gap-4 sm:grid-cols-2">
			<div class="rounded-lg border border-surface-3 bg-surface-1 p-5">
				<span class="mb-2 block text-2xl">&#128187;</span>
				<h3 class="mb-1 font-semibold text-white">Homelabber</h3>
				<p class="text-sm text-gray-400">Running a Proxmox cluster, self-hosted services, and automating everything with Home Assistant.</p>
			</div>
			<div class="rounded-lg border border-surface-3 bg-surface-1 p-5">
				<span class="mb-2 block text-2xl">&#127908;</span>
				<h3 class="mb-1 font-semibold text-white">Speaker</h3>
				<p class="text-sm text-gray-400">Spoken at hundreds of conferences worldwide. TEDx speaker. I make complex topics approachable.</p>
			</div>
			<div class="rounded-lg border border-surface-3 bg-surface-1 p-5">
				<span class="mb-2 block text-2xl">&#127916;</span>
				<h3 class="mb-1 font-semibold text-white">Film Buff</h3>
				<p class="text-sm text-gray-400">Tracking everything on <a href={SOCIAL_LINKS.letterboxd} target="_blank" rel="noopener">Letterboxd</a>. Always down to talk movies.</p>
			</div>
			<div class="rounded-lg border border-surface-3 bg-surface-1 p-5">
				<span class="mb-2 block text-2xl">&#128049;</span>
				<h3 class="mb-1 font-semibold text-white">Cat Person</h3>
				<p class="text-sm text-gray-400">Built an IoT litter box and gave a conference talk about it. Yes, really.</p>
			</div>
		</div>

		<!-- Featured Projects Link -->
		<div class="my-10 rounded-lg border border-coral/20 bg-coral/5 p-6">
			<h2 class="mb-2 text-xl font-bold text-coral">Check out my work</h2>
			<p class="mb-4 text-gray-400">
				I've built IoT projects, open source tools, demos, and more.
				My projects are more interesting than my resume.
			</p>
			<a
				href="/work"
				class="inline-block rounded-md bg-coral px-4 py-2 font-medium text-surface-0 no-underline hover:bg-teal"
			>
				View Projects &rarr;
			</a>
		</div>

		<!-- Uses -->
		<div class="my-10 rounded-lg border border-teal/20 bg-teal/5 p-6">
			<h2 class="mb-2 text-xl font-bold text-teal">My setup</h2>
			<p class="mb-4 text-gray-400">
				Curious what gear, software, and tools I use daily? I keep a running list.
			</p>
			<a
				href="/uses"
				class="inline-block rounded-md bg-teal px-4 py-2 font-medium text-surface-0 no-underline hover:bg-coral"
			>
				See my uses &rarr;
			</a>
		</div>

		<!-- Connect -->
		<h2 class="mb-4 text-xl font-bold text-white">Connect</h2>
		<div class="mb-10 flex flex-wrap gap-3">
			<a href={SOCIAL_LINKS.bluesky} target="_blank" rel="noopener" class="rounded-md border border-surface-4 px-3 py-1.5 text-sm text-gray-400 no-underline hover:border-coral hover:text-white">Bluesky</a>
			<a href={SOCIAL_LINKS.linkedin} target="_blank" rel="noopener" class="rounded-md border border-surface-4 px-3 py-1.5 text-sm text-gray-400 no-underline hover:border-coral hover:text-white">LinkedIn</a>
			<a href={SOCIAL_LINKS.github} target="_blank" rel="noopener" class="rounded-md border border-surface-4 px-3 py-1.5 text-sm text-gray-400 no-underline hover:border-coral hover:text-white">GitHub</a>
			<a href={SOCIAL_LINKS.youtube} target="_blank" rel="noopener" class="rounded-md border border-surface-4 px-3 py-1.5 text-sm text-gray-400 no-underline hover:border-coral hover:text-white">YouTube</a>
			<a href={SOCIAL_LINKS.threads} target="_blank" rel="noopener" class="rounded-md border border-surface-4 px-3 py-1.5 text-sm text-gray-400 no-underline hover:border-coral hover:text-white">Threads</a>
			<a href={SOCIAL_LINKS.instagram} target="_blank" rel="noopener" class="rounded-md border border-surface-4 px-3 py-1.5 text-sm text-gray-400 no-underline hover:border-coral hover:text-white">Instagram</a>
			<a href={SOCIAL_LINKS.letterboxd} target="_blank" rel="noopener" class="rounded-md border border-surface-4 px-3 py-1.5 text-sm text-gray-400 no-underline hover:border-coral hover:text-white">Letterboxd</a>
		</div>

		<!-- Work History (collapsed at bottom) -->
		<details class="rounded-lg border border-surface-3">
			<summary class="cursor-pointer px-6 py-4 text-gray-400 hover:text-white">
				<span class="font-medium">Work History</span>
			</summary>
			<div class="space-y-4 px-6 pb-6">
				<div class="border-l-2 border-teal pl-4">
					<h3 class="font-semibold text-white">Developer Advocate — CloudQuery</h3>
					<span class="text-sm text-gray-500">2022 – Present</span>
				</div>
				<div class="border-l-2 border-coral pl-4">
					<h3 class="font-semibold text-white">Developer Advocate — Tinybird</h3>
					<span class="text-sm text-gray-500">2023 – 2025</span>
				</div>
				<div class="border-l-2 border-lavender pl-4">
					<h3 class="font-semibold text-white">Senior Developer Advocate — SingleStore</h3>
					<span class="text-sm text-gray-500">2021 – 2023</span>
				</div>
				<div class="border-l-2 border-terminal-green pl-4">
					<h3 class="font-semibold text-white">Senior Developer Advocate — MongoDB</h3>
					<span class="text-sm text-gray-500">2019 – 2021</span>
				</div>
				<div class="border-l-2 border-sky pl-4">
					<h3 class="font-semibold text-white">Front-end Technical Lead — Best Buy</h3>
					<span class="text-sm text-gray-500">2017 – 2019</span>
				</div>
				<div class="border-l-2 border-pink pl-4">
					<h3 class="font-semibold text-white">Full-Stack JavaScript Instructor — DevLeague</h3>
					<span class="text-sm text-gray-500">2015 – 2017</span>
				</div>
			</div>
		</details>
	</div>
</BaseLayout>
