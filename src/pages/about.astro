---
import BaseLayout from '../layouts/BaseLayout.astro';
import RightNow from '../components/RightNow.astro';
import { SOCIAL_LINKS } from '../consts';
---

<BaseLayout
	title="About | Joe Karlsson"
	description="Software Engineer & Developer Advocate. TEDx Speaker, film buff, homelab enthusiast, and massive nerd."
	schemaType="AboutPage"
>
	<div class="mx-auto max-w-3xl px-4 py-8">
		<!-- Hero -->
		<div class="mb-10 flex flex-col sm:flex-row sm:items-center sm:gap-8">
			<img
				src="/images/joe-profile.webp"
				alt="Joe Karlsson speaking at a conference"
				class="mb-4 sm:mb-0 w-32 h-32 sm:w-40 sm:h-40 rounded-lg border-4 border-coral object-cover"
				width="160"
				height="160"
				loading="eager"
			/>
			<div>
				<p class="mb-2 font-mono text-sm text-coral" aria-hidden="true">~$ whoami</p>
				<h1 class="mb-2 text-3xl font-bold text-coral md:text-4xl">Joe Karlsson</h1>
				<p class="text-xl text-teal">
					Software Engineer & Developer Advocate <span class="text-gray-400 text-base"
						>(He/They)</span
					>
				</p>
			</div>
		</div>

		<div class="prose mb-10">
			<p class="text-lg">
				I'm a Software Engineer turned Developer Advocate who's spent the last decade working on
				databases, real-time data, IoT, and developer tools. I've spoken at over 100 conferences,
				given a
				<a
					href="https://www.ted.com/talks/joe_karlsson_the_art_of_computer_science"
					target="_blank"
					rel="noopener noreferrer">TEDx talk</a
				>, and built an IoT-connected cat litter box that I'm probably too proud of.
			</p>

			<p>
				My career has taken me from teaching at one of the most highly-rated software development
				boot camps on Earth, to architecting and building one of the largest eCommerce websites in
				North America at Best Buy, to building out developer communities for MongoDB, SingleStore,
				Tinybird, and CloudQuery. I'm also a film buff and avid homelab enthusiast running way too
				many containers.
			</p>
		</div>

		<!-- What I'm Into - visual cards with links -->
		<h2 class="mb-4 text-lg font-bold text-white">
			<span class="text-coral font-mono text-sm" aria-hidden="true">~$</span> cat interests.md
		</h2>
		<div class="mb-10 grid gap-4 sm:grid-cols-2">
			<a
				href="/blog/how-to-get-started-building-a-homelab-server-in-2024"
				class="group block overflow-hidden rounded-lg border border-surface-3 no-underline transition-all duration-300 hover:-translate-y-0.5 hover:border-coral/30"
			>
				<img
					src="/images/blog/how-to-get-started-building-a-homelab-server-in-2024/homelab-vaporwave.webp"
					alt="Vaporwave style homelab server illustration"
					class="w-full h-28 object-cover transition-transform group-hover:scale-[1.02]"
					loading="lazy"
				/>
				<div class="bg-surface-1 p-4">
					<h3 class="mb-1 font-semibold text-white group-hover:text-coral">Homelabber</h3>
					<p class="text-sm text-gray-400">
						Running a Proxmox cluster with 40+ containers, self-hosted services, and Home Assistant
						automating the whole house.
					</p>
				</div>
			</a>
			<a
				href="/talk-archive"
				class="group block overflow-hidden rounded-lg border border-surface-3 no-underline transition-all duration-300 hover:-translate-y-0.5 hover:border-coral/30"
			>
				<img
					src="/images/blog/the-art-of-computer-science/The-Art-of-Computer-Science.webp"
					alt="Joe Karlsson on the TEDx stage"
					class="w-full h-28 object-cover transition-transform group-hover:scale-[1.02]"
					loading="lazy"
				/>
				<div class="bg-surface-1 p-4">
					<h3 class="mb-1 font-semibold text-white group-hover:text-coral">Speaker</h3>
					<p class="text-sm text-gray-400">
						100+ conferences worldwide. TEDx speaker. I talk about databases, IoT, and the weird
						stuff I build at home.
					</p>
				</div>
			</a>
			<a
				href={SOCIAL_LINKS.letterboxd}
				target="_blank"
				rel="noopener noreferrer"
				class="group block overflow-hidden rounded-lg border border-surface-3 no-underline transition-all duration-300 hover:-translate-y-0.5 hover:border-coral/30"
			>
				<div class="bg-surface-1 p-4 h-full flex flex-col justify-center">
					<span class="mb-2 block text-3xl">&#127916;</span>
					<h3 class="mb-1 font-semibold text-white group-hover:text-coral">Film Buff</h3>
					<p class="text-sm text-gray-400">
						I watch a lot of movies and track everything on Letterboxd. Always happy to trade
						recommendations.
					</p>
				</div>
			</a>
			<a
				href="/blog/an-introduction-to-iot-internet-of-toilets"
				class="group block overflow-hidden rounded-lg border border-surface-3 no-underline transition-all duration-300 hover:-translate-y-0.5 hover:border-coral/30"
			>
				<img
					src="/images/blog/an-introduction-to-iot-internet-of-toilets/og-iot-toilet.webp"
					alt="IoT litter box project with Raspberry Pi and sensors"
					class="w-full h-28 object-cover transition-transform group-hover:scale-[1.02]"
					loading="lazy"
				/>
				<div class="bg-surface-1 p-4">
					<h3 class="mb-1 font-semibold text-white group-hover:text-coral">
						Cat Person / IoT Tinkerer
					</h3>
					<p class="text-sm text-gray-400">
						Built an IoT litter box with a Raspberry Pi to monitor my cat's health. Gave a
						conference talk about it. Yes, really.
					</p>
				</div>
			</a>
		</div>

		<!-- Right Now -->
		<h2 class="mb-4 text-lg font-bold text-white">
			<span class="text-coral font-mono text-sm" aria-hidden="true">~$</span> cat now.md
		</h2>
		<div class="mb-10">
			<RightNow columns={2} />
		</div>

		<!-- Featured Content -->
		<h2 class="mb-4 text-lg font-bold text-white">
			<span class="text-coral font-mono text-sm" aria-hidden="true">~$</span> ls featured/
		</h2>
		<div class="mb-10 space-y-4">
			<!-- TEDx Talk - full width hero -->
			<a
				href="https://www.ted.com/talks/joe_karlsson_the_art_of_computer_science"
				target="_blank"
				rel="noopener noreferrer"
				class="group block overflow-hidden rounded-lg border border-coral/20 no-underline transition-all duration-300 hover:-translate-y-0.5 hover:border-coral/30"
			>
				<img
					src="/images/blog/the-art-of-computer-science/The-Art-of-Computer-Science.webp"
