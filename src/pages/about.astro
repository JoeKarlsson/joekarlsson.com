---
import BaseLayout from '../layouts/BaseLayout.astro';
import RightNow from '../components/RightNow.astro';
import { SOCIAL_LINKS } from '../consts';
---

<BaseLayout
	title="About | Joe Karlsson"
	description="Software Engineer & Developer Advocate leading DevRel at CloudQuery. 15+ years of experience at MongoDB, SingleStore, Tinybird, and Best Buy. TEDx Speaker, homelab enthusiast."
	schemaType="AboutPage"
>
	<div class="mx-auto max-w-3xl px-4 py-8">
		<!-- Hero -->
		<div class="mb-10 flex flex-col sm:flex-row sm:items-center sm:gap-8">
			<img
				src="/images/joe-profile.webp"
				alt="Joe Karlsson speaking at a conference"
				class="mb-4 sm:mb-0 w-32 h-32 sm:w-40 sm:h-40 rounded-lg border-4 border-coral object-cover"
				width="160"
				height="160"
				loading="eager"
			/>
			<div>
				<p class="mb-2 font-mono text-sm text-coral" aria-hidden="true">~$ whoami</p>
				<h1 class="mb-2 text-3xl font-bold text-coral md:text-4xl">Joe Karlsson</h1>
				<p class="text-xl text-teal">
					Software Engineer & Developer Advocate <span class="text-gray-400 text-base"
						>(He/They)</span
					>
				</p>
			</div>
		</div>

		<div class="prose mb-10">
			<p class="text-lg">
				I lead developer relations at CloudQuery, where I help developers build data pipelines
				through demos, tutorials, and content. I've been a professional software engineer for
				over 15 years, and I've spent most of that time at data companies - MongoDB, SingleStore,
				Tinybird, and now CloudQuery - making complex data topics click for developers through
				whatever medium works best.
			</p>

			<p>
				Before DevRel, I was a Technical Lead at Best Buy, where I helped architect and scale one of
				the top 10 eCommerce sites in North America - production apps handling thousands of requests
				per second. That experience building real systems at scale is what I bring to everything I do
				now. I've also given <a
					href="https://www.ted.com/talks/joe_karlsson_the_art_of_computer_science"
					target="_blank"
					rel="noopener noreferrer">a TEDx talk</a
				> and spoken at 100+ conferences, studied CS at Gustavus Adolphus College, and I run a
				homelab with way too many containers.
			</p>
		</div>

		<!-- Companies -->
		<div class="mb-10">
			<p class="mb-3 text-xs font-mono text-gray-500 text-center">Previously at</p>
			<div class="flex flex-wrap items-center justify-center gap-8 rounded-lg border border-surface-3 bg-surface-1 px-6 py-5">
				<div class="flex flex-col items-center gap-1.5">
					<img
						src="/images/logos/bestbuy.webp"
						alt="Best Buy logo"
						class="h-10 w-10 rounded"
						width="40"
						height="40"
						loading="eager"
					/>
					<span class="text-[10px] font-mono text-gray-500">Best Buy</span>
				</div>
				<div class="flex flex-col items-center gap-1.5">
					<img
						src="/images/logos/mongodb.webp"
						alt="MongoDB logo"
						class="h-10 w-10 rounded"
						width="40"
						height="40"
						loading="eager"
					/>
					<span class="text-[10px] font-mono text-gray-500">MongoDB</span>
				</div>
				<div class="flex flex-col items-center gap-1.5">
					<img
						src="/images/logos/singlestore.webp"
						alt="SingleStore logo"
						class="h-10 w-10 rounded"
						width="40"
						height="40"
						loading="eager"
					/>
					<span class="text-[10px] font-mono text-gray-500">SingleStore</span>
				</div>
				<div class="flex flex-col items-center gap-1.5">
					<img
						src="/images/logos/tinybird.webp"
						alt="Tinybird logo"
						class="h-10 w-10 rounded"
						width="40"
						height="40"
						loading="eager"
					/>
					<span class="text-[10px] font-mono text-gray-500">Tinybird</span>
				</div>
				<div class="flex flex-col items-center gap-1.5">
					<img
						src="/images/logos/cloudquery.webp"
						alt="CloudQuery logo"
						class="h-10 w-10 rounded"
						width="40"
						height="40"
						loading="eager"
					/>
					<span class="text-[10px] font-mono text-gray-500">CloudQuery</span>
				</div>
				<div class="flex flex-col items-center gap-1.5">
					<img
						src="/images/logos/devleague.webp"
						alt="DevLeague logo"
						class="h-10 w-10 rounded"
						width="40"
						height="40"
						loading="eager"
					/>
					<span class="text-[10px] font-mono text-gray-500">DevLeague</span>
				</div>
			</div>
		</div>

		<!-- Stats -->
		<div class="mb-10 grid grid-cols-2 gap-3 sm:grid-cols-4">
			<div class="rounded-lg border border-surface-3 bg-surface-1 p-4 text-center">
				<p class="text-2xl font-bold text-coral">100+</p>
				<p class="text-xs text-gray-400">Conference Talks</p>
			</div>
			<div class="rounded-lg border border-surface-3 bg-surface-1 p-4 text-center">
				<p class="text-2xl font-bold text-coral">15+</p>
				<p class="text-xs text-gray-400">Years in Tech</p>
			</div>
			<div class="rounded-lg border border-surface-3 bg-surface-1 p-4 text-center">
				<p class="text-2xl font-bold text-coral">25K+</p>
				<p class="text-xs text-gray-400">TikTok Followers</p>
			</div>
			<div class="rounded-lg border border-surface-3 bg-surface-1 p-4 text-center">
				<p class="text-2xl font-bold text-coral">14+</p>
				<p class="text-xs text-gray-400">Podcast Appearances</p>
			</div>
		</div>

		<!-- Specializations -->
		<h2 class="mb-4 text-lg font-bold text-white">
			<span class="text-coral font-mono text-sm" aria-hidden="true">~$</span> cat specializations.md
		</h2>
		<div class="mb-10 grid gap-3 sm:grid-cols-3">
			<div class="rounded-lg border border-surface-3 bg-surface-1 p-4">
				<h3 class="mb-1 font-semibold text-coral">Data Systems</h3>
				<p class="text-sm text-gray-400">
					I've worked at four data companies (MongoDB, SingleStore, Tinybird, CloudQuery) and
					scaled Best Buy's eCommerce platform. I know databases.
				</p>
			</div>
			<div class="rounded-lg border border-surface-3 bg-surface-1 p-4">
				<h3 class="mb-1 font-semibold text-coral">Teaching Complex Topics</h3>
				<p class="text-sm text-gray-400">
					From coding bootcamp instructor to TEDx speaker. I make technical concepts click
					through talks, demos, and content that people actually want to watch.
				</p>
			</div>
			<div class="rounded-lg border border-surface-3 bg-surface-1 p-4">
				<h3 class="mb-1 font-semibold text-coral">Building Weird Stuff</h3>
				<p class="text-sm text-gray-400">
					IoT cat litter boxes, crop art from millet kernels, hackathons for terrible ideas.
					The side projects are what make the talks interesting.
				</p>
			</div>
		</div>

		<!-- Recognition -->
		<h2 class="mb-4 text-lg font-bold text-white">
			<span class="text-coral font-mono text-sm" aria-hidden="true">~$</span> cat recognition.md
		</h2>
		<div class="mb-10 grid gap-3 sm:grid-cols-2">
			<div class="rounded-lg border border-surface-3 bg-surface-1 p-4">
				<h3 class="text-sm font-semibold text-coral">TEDx Speaker & Conference Keynote</h3>
				<p class="text-xs text-gray-400">
					"The Art of Computer Science" - delivered as a TEDx talk and keynote at multiple
					conferences
				</p>
			</div>
			<a
				href="https://unclebigbay.com/10-must-follow-developers-on-tik-tok"
				target="_blank"
				rel="noopener noreferrer"
				class="group block rounded-lg border border-surface-3 bg-surface-1 p-4 no-underline transition-all duration-300 hover:-translate-y-0.5 hover:border-coral/30"
			>
				<h3 class="text-sm font-semibold text-coral group-hover:text-white">
					#1 on "10 Must-Follow Developers on TikTok"
				</h3>
				<p class="text-xs text-gray-400">25K+ followers, 844K+ likes</p>
			</a>
			<div class="rounded-lg border border-surface-3 bg-surface-1 p-4">
				<h3 class="text-sm font-semibold text-coral">Published Author</h3>
				<p class="text-xs text-gray-400">
					The New Stack, MongoDB Developer Hub, Tinybird blog, Medium, DEV Community
				</p>
			</div>
			<a
				href="https://stupidshitnooneinhawaiineedshackathon.github.io/"
				target="_blank"
				rel="noopener noreferrer"
				class="group block rounded-lg border border-surface-3 bg-surface-1 p-4 no-underline transition-all duration-300 hover:-translate-y-0.5 hover:border-coral/30"
			>
				<h3 class="text-sm font-semibold text-coral group-hover:text-white">
					Hackathon Organizer
				</h3>
				<p class="text-xs text-gray-400">
					Co-organized "Stupid Shit No One In Hawaii Needs" hackathon (2016). Sponsored by
					GitHub & Front End Masters.
				</p>
			</a>
			<div class="rounded-lg border border-surface-3 bg-surface-1 p-4">
				<h3 class="text-sm font-semibold text-coral">Arctic Code Vault Contributor</h3>
				<p class="text-xs text-gray-400">
					Code preserved in GitHub's Arctic Code Vault for future generations
				</p>
			</div>
			<div class="rounded-lg border border-surface-3 bg-surface-1 p-4">
				<h3 class="text-sm font-semibold text-coral">Coding Bootcamp Instructor</h3>
				<p class="text-xs text-gray-400">
					Taught full-stack JavaScript at DevLeague, one of the top 10 coding bootcamps
					worldwide (Honolulu, 2015-2017)
				</p>
			</div>
		</div>

		<!-- As Heard On -->
		<h2 class="mb-4 text-lg font-bold text-white">
			<span class="text-coral font-mono text-sm" aria-hidden="true">~$</span> cat as-seen-on.md
		</h2>
		<div class="mb-10 grid gap-4 sm:grid-cols-2">
			<a
				href="https://hanselminutes.com/752/document-databases-and-mongo-with-engineer-joe-karlsson"
				target="_blank"
				rel="noopener noreferrer"
				class="group flex items-center gap-4 overflow-hidden rounded-lg border border-surface-3 bg-surface-1 no-underline transition-all duration-300 hover:-translate-y-0.5 hover:border-coral/30"
			>
				<img
					src="/images/podcasts/hanselminutes.webp"
					alt="Hanselminutes podcast artwork"
					class="h-24 w-24 flex-shrink-0 object-cover"
					width="96"
					height="96"
					loading="lazy"
				/>
				<div class="py-3 pr-4">
					<h3 class="text-sm font-semibold text-white group-hover:text-coral leading-tight">
						Hanselminutes
					</h3>
					<p class="text-xs text-gray-400">with Scott Hanselman</p>
					<p class="mt-1 text-xs text-gray-500">Document Databases and Mongo</p>
				</div>
			</a>
			<a
				href="https://www.lastweekinaws.com/podcast/screaming-in-the-cloud/when-data-is-your-brand-and-your-job-with-joe-karlsson/"
				target="_blank"
				rel="noopener noreferrer"
				class="group flex items-center gap-4 overflow-hidden rounded-lg border border-surface-3 bg-surface-1 no-underline transition-all duration-300 hover:-translate-y-0.5 hover:border-coral/30"
			>
				<img
					src="/images/podcasts/screaming-cloud.webp"
					alt="Screaming in the Cloud podcast artwork"
					class="h-24 w-24 flex-shrink-0 object-cover"
					width="96"
					height="96"
					loading="lazy"
				/>
				<div class="py-3 pr-4">
					<h3 class="text-sm font-semibold text-white group-hover:text-coral leading-tight">
						Screaming in the Cloud
					</h3>
					<p class="text-xs text-gray-400">with Corey Quinn (Last Week in AWS)</p>
					<p class="mt-1 text-xs text-gray-500">When Data is Your Brand and Your Job</p>
				</div>
			</a>
			<a
				href="https://topenddevs.com/podcasts/javascript-jabber/episodes/jsj-436-mongodb-basics-with-joe-karlsson"
				target="_blank"
				rel="noopener noreferrer"
				class="group flex items-center gap-4 overflow-hidden rounded-lg border border-surface-3 bg-surface-1 no-underline transition-all duration-300 hover:-translate-y-0.5 hover:border-coral/30"
			>
				<img
					src="/images/podcasts/javascript-jabber.webp"
					alt="JavaScript Jabber podcast artwork"
					class="h-24 w-24 flex-shrink-0 object-cover"
					width="96"
					height="96"
					loading="lazy"
				/>
				<div class="py-3 pr-4">
					<h3 class="text-sm font-semibold text-white group-hover:text-coral leading-tight">
						JavaScript Jabber
					</h3>
					<p class="text-xs text-gray-400">Two episodes - MongoDB & IoT</p>
					<p class="mt-1 text-xs text-gray-500">JSJ 432 & JSJ 436</p>
				</div>
			</a>
			<a
				href="https://dev.to/codenewbie/s19-e6-how-to-make-learning-databases-fun-and-approachable-joe-karlsson"
				target="_blank"
				rel="noopener noreferrer"
				class="group flex items-center gap-4 overflow-hidden rounded-lg border border-surface-3 bg-surface-1 no-underline transition-all duration-300 hover:-translate-y-0.5 hover:border-coral/30"
			>
				<img
					src="/images/podcasts/codenewbie.webp"
					alt="CodeNewbie podcast artwork"
					class="h-24 w-24 flex-shrink-0 object-cover"
					width="96"
					height="96"
					loading="lazy"
				/>
				<div class="py-3 pr-4">
					<h3 class="text-sm font-semibold text-white group-hover:text-coral leading-tight">
						CodeNewbie
					</h3>
					<p class="text-xs text-gray-400">Making databases fun and approachable</p>
					<p class="mt-1 text-xs text-gray-500">Season 19, Episode 6</p>
				</div>
			</a>
		</div>
		<!-- More Appearances -->
		<h3 class="mb-3 text-sm font-semibold text-gray-400">+ More Appearances</h3>
		<div class="mb-10 grid gap-3 sm:grid-cols-3">
			<a
				href="https://8bits.tv/8-bits-with-joe-karlsson/"
				target="_blank"
				rel="noopener noreferrer"
				class="group rounded-lg border border-surface-3 bg-surface-1 p-3 no-underline transition-all duration-300 hover:-translate-y-0.5 hover:border-coral/30"
			>
				<h3 class="text-sm font-semibold text-white group-hover:text-coral">8 Bits</h3>
				<p class="text-xs text-gray-400">with Chloe Condon & Brandon Minnick</p>
			</a>
			<a
				href="https://www.communitypulse.io/57-devrel-content-channels/"
				target="_blank"
				rel="noopener noreferrer"
				class="group rounded-lg border border-surface-3 bg-surface-1 p-3 no-underline transition-all duration-300 hover:-translate-y-0.5 hover:border-coral/30"
			>
				<h3 class="text-sm font-semibold text-white group-hover:text-coral">Community Pulse</h3>
				<p class="text-xs text-gray-400">DevRel Content Channels (w/ Cassidy Williams)</p>
			</a>
			<a
				href="https://podcasts.apple.com/us/podcast/dok-talks-120-a-gentle-introduction-to-building/id1524821862?i=1000553416566"
				target="_blank"
				rel="noopener noreferrer"
				class="group rounded-lg border border-surface-3 bg-surface-1 p-3 no-underline transition-all duration-300 hover:-translate-y-0.5 hover:border-coral/30"
			>
				<h3 class="text-sm font-semibold text-white group-hover:text-coral">
					Data on Kubernetes
				</h3>
				<p class="text-xs text-gray-400">Building Data Intensive Applications</p>
			</a>
			<a
				href="https://www.lonti.com/podcast/episode-9"
				target="_blank"
				rel="noopener noreferrer"
				class="group rounded-lg border border-surface-3 bg-surface-1 p-3 no-underline transition-all duration-300 hover:-translate-y-0.5 hover:border-coral/30"
			>
				<h3 class="text-sm font-semibold text-white group-hover:text-coral">
					Coding Over Cocktails
				</h3>
				<p class="text-xs text-gray-400">Diving deep into databases</p>
			</a>
			<a
				href="https://open.spotify.com/episode/3gg6uix4qtAIswZV3k3FXq"
				target="_blank"
				rel="noopener noreferrer"
				class="group rounded-lg border border-surface-3 bg-surface-1 p-3 no-underline transition-all duration-300 hover:-translate-y-0.5 hover:border-coral/30"
			>
				<h3 class="text-sm font-semibold text-white group-hover:text-coral">REACT Podcast</h3>
				<p class="text-xs text-gray-400">Serverless Apps With React (Ep. 126)</p>
			</a>
		</div>

		<!-- Featured Videos -->
		<h2 class="mb-4 text-lg font-bold text-white">
			<span class="text-coral font-mono text-sm" aria-hidden="true">~$</span> ls videos/
		</h2>
		<div class="mb-10 space-y-6">
			<!-- TEDx Talk - hero embed -->
			<div>
				<h3 class="mb-2 text-sm font-semibold text-white">
					<span class="font-mono text-xs text-coral">TEDx</span> The Art of Computer Science
				</h3>
				<div class="aspect-video overflow-hidden rounded-lg border border-coral/20">
					<iframe
						width="100%"
						height="100%"
						src="https://www.youtube-nocookie.com/embed/GiNa2jen-lg"
						title="The Art of Computer Science - TEDx Talk by Joe Karlsson"
						frameborder="0"
						allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
						allowfullscreen
						loading="lazy"
						sandbox="allow-same-origin allow-scripts allow-presentation"
					></iframe>
				</div>
			</div>
			<!-- Two more embeds -->
			<div class="grid gap-6 sm:grid-cols-2">
				<div>
					<h3 class="mb-2 text-sm font-semibold text-white">
						MongoDB Schema Design Best Practices
					</h3>
					<div class="aspect-video overflow-hidden rounded-lg border border-surface-3">
						<iframe
							width="100%"
							height="100%"
							src="https://www.youtube-nocookie.com/embed/QAqK-R9HUhc"
							title="MongoDB Schema Design Best Practices"
							frameborder="0"
							allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
							allowfullscreen
							loading="lazy"
						></iframe>
					</div>
				</div>
				<div>
					<h3 class="mb-2 text-sm font-semibold text-white">
						Bringing JavaScript to the IoT Edge
					</h3>
					<div class="aspect-video overflow-hidden rounded-lg border border-surface-3">
						<iframe
							width="100%"
							height="100%"
							src="https://www.youtube-nocookie.com/embed/711Sb55fzdg"
							title="Bringing JavaScript to the IoT Edge"
							frameborder="0"
							allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
							allowfullscreen
							loading="lazy"
						></iframe>
					</div>
				</div>
			</div>
			<!-- More talks as thumbnail links -->
			<div class="grid gap-3 sm:grid-cols-3">
				<a
					href="https://www.youtube.com/watch?v=UuNVpLIOHW8"
					target="_blank"
					rel="noopener noreferrer"
					class="group block overflow-hidden rounded-lg border border-surface-3 no-underline transition-all duration-300 hover:-translate-y-0.5 hover:border-coral/30"
				>
					<img
						src="https://img.youtube.com/vi/UuNVpLIOHW8/mqdefault.jpg"
						alt="Mapping SQL Terms and Concepts to MongoDB"
						class="w-full h-28 object-cover transition-transform duration-300 group-hover:scale-105"
						loading="lazy"
					/>
					<div class="bg-surface-1 p-3">
						<h3 class="text-xs font-semibold text-white group-hover:text-coral">
							Mapping SQL to MongoDB
						</h3>
					</div>
				</a>
				<a
					href="https://www.youtube.com/watch?v=bIFrJJkUftA"
					target="_blank"
					rel="noopener noreferrer"
					class="group block overflow-hidden rounded-lg border border-surface-3 no-underline transition-all duration-300 hover:-translate-y-0.5 hover:border-coral/30"
				>
					<img
						src="https://img.youtube.com/vi/bIFrJJkUftA/mqdefault.jpg"
						alt="Getting Started with SingleStore"
						class="w-full h-28 object-cover transition-transform duration-300 group-hover:scale-105"
						loading="lazy"
					/>
					<div class="bg-surface-1 p-3">
						<h3 class="text-xs font-semibold text-white group-hover:text-coral">
							Getting Started with SingleStore
						</h3>
					</div>
				</a>
				<a
					href="https://www.youtube.com/watch?v=6bHYDUzY9j0"
					target="_blank"
					rel="noopener noreferrer"
					class="group block overflow-hidden rounded-lg border border-surface-3 no-underline transition-all duration-300 hover:-translate-y-0.5 hover:border-coral/30"
				>
					<img
						src="https://img.youtube.com/vi/6bHYDUzY9j0/mqdefault.jpg"
						alt="8-Bits with Joe Karlsson"
						class="w-full h-28 object-cover transition-transform duration-300 group-hover:scale-105"
						loading="lazy"
					/>
					<div class="bg-surface-1 p-3">
						<h3 class="text-xs font-semibold text-white group-hover:text-coral">
							8-Bits with Joe Karlsson
						</h3>
					</div>
				</a>
			</div>
			<div class="text-center">
				<a
					href={SOCIAL_LINKS.youtube}
					target="_blank"
					rel="noopener noreferrer"
					class="inline-block rounded-md bg-surface-2 px-4 py-2 font-mono text-sm text-coral no-underline hover:bg-surface-3"
				>
					See all talks on YouTube &rarr;
				</a>
			</div>
		</div>

		<!-- TikTok -->
		<h2 class="mb-4 text-lg font-bold text-white">
			<span class="text-coral font-mono text-sm" aria-hidden="true">~$</span> ls tiktok/
		</h2>
		<div class="mb-10 grid gap-4 sm:grid-cols-3">
			<div class="overflow-hidden rounded-lg border border-surface-3">
				<blockquote
					class="tiktok-embed"
