					class="w-full h-48 object-cover transition-transform group-hover:scale-[1.02]"
					loading="lazy"
				/>
				<div class="bg-surface-1 p-4">
					<span class="text-xs font-mono text-coral">TEDx Talk</span>
					<h3 class="font-semibold text-white group-hover:text-coral">
						The Art of Computer Science
					</h3>
				</div>
			</a>
			<!-- Blog posts + YouTube -->
			<div class="grid gap-4 sm:grid-cols-3">
				<a
					href="/blog/an-introduction-to-iot-internet-of-toilets"
					class="group block overflow-hidden rounded-lg border border-surface-3 no-underline transition-all duration-300 hover:-translate-y-0.5 hover:border-coral/30"
				>
					<img
						src="/images/blog/an-introduction-to-iot-internet-of-toilets/og-iot-toilet.webp"
						alt="IoT Internet of Toilets project with Raspberry Pi and sensors"
						class="w-full h-32 object-cover transition-transform group-hover:scale-[1.02]"
						loading="lazy"
					/>
					<div class="bg-surface-1 p-3">
						<span class="text-xs font-mono text-teal">Blog</span>
						<h3 class="text-sm font-semibold text-white group-hover:text-coral">
							IoT (Internet of Toilets)
						</h3>
					</div>
				</a>
				<a
					href="/blog/how-to-get-started-building-a-homelab-server-in-2024"
					class="group block overflow-hidden rounded-lg border border-surface-3 no-underline transition-all duration-300 hover:-translate-y-0.5 hover:border-coral/30"
