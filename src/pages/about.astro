					<img
						src="/images/blog/how-to-get-started-building-a-homelab-server-in-2024/homelab-vaporwave.webp"
						alt="Vaporwave style homelab server illustration"
						class="w-full h-32 object-cover transition-transform group-hover:scale-[1.02]"
						loading="lazy"
					/>
					<div class="bg-surface-1 p-3">
						<span class="text-xs font-mono text-teal">Blog</span>
						<h3 class="text-sm font-semibold text-white group-hover:text-coral">
							Building a Homelab Server
						</h3>
					</div>
				</a>
				<a
					href={SOCIAL_LINKS.youtube}
					target="_blank"
					rel="noopener noreferrer"
					class="group flex flex-col items-center justify-center rounded-lg border border-surface-3 bg-surface-1 p-5 no-underline transition-all duration-300 hover:-translate-y-0.5 hover:border-coral/30"
				>
					<span class="mb-2 text-4xl">&#9654;&#65039;</span>
					<span class="text-xs font-mono text-teal">YouTube</span>
					<h3 class="mt-1 text-sm font-semibold text-center text-white group-hover:text-coral">
						100+ Conference Talks
					</h3>
				</a>
			</div>
		</div>

		<!-- Newsletter CTA -->
		<div class="my-10 rounded-lg border border-lavender/20 bg-lavender/5 p-6">
			<h2 class="mb-2 text-xl font-bold text-white">
				<span class="text-coral font-mono text-sm" aria-hidden="true">~$</span> cat newsletter.md
			</h2>
			<p class="mb-4 text-gray-400">
				I send out posts about databases, self-hosting, homelabs, IoT, and whatever else I'm
				building. No spam, no fluff - just the stuff I'm actually working on.
			</p>
			<a
				href={SOCIAL_LINKS.substack}
				target="_blank"
				rel="noopener noreferrer"
				class="inline-block rounded-md bg-lavender px-4 py-2 font-medium text-surface-0 no-underline hover:bg-coral"
			>
				Subscribe on Substack &rarr;
			</a>
		</div>

		<!-- Featured Projects Link -->
		<div class="my-10 rounded-lg border border-coral/20 bg-coral/5 p-6">
			<h2 class="mb-2 text-xl font-bold text-white">
				<span class="text-coral font-mono text-sm" aria-hidden="true">~$</span> ls work/
			</h2>
			<p class="mb-4 text-gray-400">
				I've built IoT projects, open source tools, demos, and more. My projects are more
				interesting than my resume.
			</p>
			<a
