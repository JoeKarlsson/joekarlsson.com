---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Privacy Policy | Joe Karlsson" description="Privacy policy for joekarlsson.com">
	<div class="mx-auto max-w-3xl px-4 py-8">
		<h1 class="mb-8 text-3xl font-bold text-white">Privacy Policy</h1>
		<div class="prose">
			<p>This website is a static site that collects minimal data.</p>

			<h2>Analytics</h2>
			<p>
				This site uses <a href="https://plausible.io" target="_blank" rel="noopener">Plausible Analytics</a>,
				a privacy-friendly, self-hosted analytics tool. Plausible does not use cookies and does not
				collect any personal data. All data is aggregated and no individual visitors can be identified.
			</p>

			<h2>Cookies</h2>
			<p>This website does not use cookies.</p>

			<h2>Third-Party Services</h2>
			<p>
				This site is served through Cloudflare, which may log IP addresses for security purposes.
				Google Fonts are loaded for typography.
			</p>

			<h2>Contact</h2>
			<p>
				If you have questions about this privacy policy, please <a href="/contact">contact me</a>.
			</p>
		</div>
	</div>
</BaseLayout>
