---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects, CATEGORY_META } from '../data/projects';
import { SOCIAL_LINKS } from '../consts';

const featuredProject = projects.find((p) => p.featured);
const nonFeatured = projects.filter((p) => !p.featured);

const categories = ['iot', 'web', 'games', 'dev-tools', 'homelab'] as const;
---

<BaseLayout
	title="Work & Projects | Joe Karlsson"
	description="Joe Karlsson's projects, demos, open source work, and portfolio."
	schemaType="CollectionPage"
>
	<div class="mx-auto max-w-5xl px-4 py-8">
		<p class="mb-2 font-mono text-sm text-coral" aria-hidden="true">~$ ls work/</p>
		<h1 class="mb-2 text-3xl font-bold text-coral md:text-4xl">Work & Projects</h1>
		<p class="mb-10 text-gray-400">
			I build things - software, hardware, IoT contraptions, and the occasional questionable idea.
			Here's a collection of projects I've shipped over the years.
		</p>

		{/* Featured Project */}
		{
			featuredProject && (
				<a
					href={featuredProject.sourceUrl || featuredProject.blogUrl || '#'}
					target={featuredProject.sourceUrl ? '_blank' : undefined}
					rel={featuredProject.sourceUrl ? 'noopener noreferrer' : undefined}
					class="group mb-12 block overflow-hidden rounded-lg border border-coral/30 bg-surface-1 no-underline transition-all hover:border-coral/50 hover:bg-surface-2"
				>
					<div class="md:flex">
						<img
							src={featuredProject.image}
							alt={featuredProject.imageAlt}
							class="h-48 w-full object-cover md:h-auto md:w-1/2"
						/>
						<div class="flex flex-col justify-center p-6">
							<p class="mb-2 font-mono text-xs text-coral">Featured Project</p>
							<h2 class="mb-2 text-2xl font-bold text-white transition-colors group-hover:text-coral">
								{featuredProject.title}
							</h2>
							<div class="mb-3 flex flex-wrap gap-1">
								{featuredProject.tech.map((t) => (
									<span class="rounded-full bg-surface-3 px-2 py-0.5 font-mono text-[10px] text-gray-400">
										{t}
									</span>
								))}
							</div>
							{featuredProject.stars && (
								<p class="mb-2 font-mono text-xs text-gray-400">
									{featuredProject.stars} stars on GitHub
								</p>
							)}
							<p class="line-clamp-3 text-sm text-gray-400">{featuredProject.description}</p>
							<div class="mt-4 flex items-center gap-4">
								{featuredProject.sourceUrl && (
									<span class="flex items-center gap-1 font-mono text-xs text-coral">
										<svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24">
											<path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
										</svg>
										Source
									</span>
								)}
								{featuredProject.blogUrl && (
									<span class="flex items-center gap-1 font-mono text-xs text-coral">
										<svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												stroke-width="2"
												d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"
											/>
										</svg>
										Blog Post
									</span>
								)}
							</div>
						</div>
					</div>
				</a>
			)
		}

		{/* Project Categories */}
		{
			categories.map((catKey) => {
				const meta = CATEGORY_META[catKey];
				const catProjects = nonFeatured.filter((p) => p.category === catKey);
				if (catProjects.length === 0) return null;
				return (
					<>
						<h2 class="mb-4 text-xl font-bold text-white">
							<span class="text-coral font-mono text-sm" aria-hidden="true">
								~$
							</span>{' '}
							{meta.command}
						</h2>
						<div class="mb-10 grid gap-4 sm:grid-cols-2">
							{catProjects.map((project) => (
								<ProjectCard project={project} />
							))}
						</div>
					</>
				);
			})
		}

		{/* All repos link */}
		<div class="mb-10 rounded-lg border border-surface-3 bg-surface-1 p-6 text-center">
			<p class="mb-3 text-gray-400">Want to see everything?</p>
			<a
				href={SOCIAL_LINKS.github}
				target="_blank"
				rel="noopener noreferrer"
				class="inline-block rounded-md bg-coral px-5 py-2.5 font-medium text-surface-0 no-underline hover:bg-teal"
			>
				View all repos on GitHub &rarr;
			</a>
		</div>

		{/* Work History */}
		<details class="rounded-lg border border-surface-3" open>
			<summary class="cursor-pointer px-6 py-4 text-gray-400 hover:text-white">
				<span class="font-medium">Work History</span>
			</summary>
			<div class="space-y-4 px-6 pb-6">
				<div class="border-l-2 border-teal pl-4">
					<h3 class="font-semibold text-white">Developer Advocate - CloudQuery</h3>
					<span class="text-sm text-gray-400">2025 – Present</span>
					<p class="mt-1 text-sm text-gray-400">
						Developer relations and content for the open-source ELT framework. Creating demos,
						tutorials, and developer resources.
					</p>
				</div>
				<div class="border-l-2 border-coral pl-4">
					<h3 class="font-semibold text-white">Developer Advocate - Tinybird</h3>
					<span class="text-sm text-gray-400">2023 – 2025</span>
					<p class="mt-1 text-sm text-gray-400">
						Empowered developers building real-time analytics applications. Created documentation,
						demos, blog posts, webinars, and workshops.
					</p>
				</div>
				<div class="border-l-2 border-lavender pl-4">
					<h3 class="font-semibold text-white">Senior Developer Advocate - SingleStore</h3>
					<span class="text-sm text-gray-400">2021 – 2023</span>
					<p class="mt-1 text-sm text-gray-400">
						Led community conversations around scaling SQL workloads. Built demos and content for
						the distributed SQL database.
					</p>
				</div>
				<div class="border-l-2 border-terminal-green pl-4">
					<h3 class="font-semibold text-white">Senior Developer Advocate - MongoDB</h3>
					<span class="text-sm text-gray-400">2019 – 2021</span>
					<p class="mt-1 text-sm text-gray-400">
						Built developer community, created tutorials, demos, and educational content. Subject
						matter expert for developer experience.
					</p>
				</div>
				<div class="border-l-2 border-sky pl-4">
					<h3 class="font-semibold text-white">Front-end Technical Lead - Best Buy</h3>
					<span class="text-sm text-gray-400">2017 – 2019</span>
					<p class="mt-1 text-sm text-gray-400">
						Engineered high-performance solutions for one of the top 10 eCommerce sites in North
						America. Scaled production apps handling thousands of requests per second.
					</p>
				</div>
				<div class="border-l-2 border-pink pl-4">
					<h3 class="font-semibold text-white">Full-Stack JavaScript Instructor - DevLeague</h3>
					<span class="text-sm text-gray-400">2015 – 2017</span>
					<p class="mt-1 text-sm text-gray-400">
						Taught full-stack JavaScript at one of the top 10 coding bootcamps worldwide. Created
						curriculum and prepared students for software engineering careers in Honolulu.
					</p>
				</div>
			</div>
		</details>
	</div>
</BaseLayout>
