---
import { getCollection } from 'astro:content';
import BlogCard from '../../../components/BlogCard.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';

function getReadingTime(body: string): number {
	const words = body.trim().split(/\s+/).length;
	return Math.max(1, Math.ceil(words / 250));
}

export async function getStaticPaths() {
	const posts = await getCollection('blog');

	// Collect all unique categories
	const categoryMap = new Map<string, typeof posts>();
	for (const post of posts) {
		for (const cat of post.data.categories) {
			const slug = cat.toLowerCase().replace(/\s+/g, '-');
			if (!categoryMap.has(slug)) categoryMap.set(slug, []);
			categoryMap.get(slug)!.push(post);
		}
	}

	return [...categoryMap.entries()].map(([slug, catPosts]) => ({
		params: { category: slug },
		props: {
			category: catPosts[0].data.categories.find(
				(c: string) => c.toLowerCase().replace(/\s+/g, '-') === slug,
			)!,
			posts: catPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
		},
	}));
}

const { category, posts } = Astro.props;

// Get all categories for the filter bar
const allPosts = await getCollection('blog');
const categoryCounts = new Map<string, number>();
for (const post of allPosts) {
	for (const cat of post.data.categories) {
		categoryCounts.set(cat, (categoryCounts.get(cat) || 0) + 1);
	}
}
const categories = [...categoryCounts.entries()].sort((a, b) => b[1] - a[1]);
const currentSlug = category.toLowerCase().replace(/\s+/g, '-');
---

<BaseLayout
	title={`${category} | Blog | Joe Karlsson`}
	description={`Browse ${posts.length} posts about ${category.toLowerCase()} by Joe Karlsson - software engineer and developer advocate.`}
	schemaType="CollectionPage"
>
	<div class="mx-auto max-w-5xl px-4 py-8">
		<div class="mb-8">
			<p class="mb-2 font-mono text-sm text-coral" aria-hidden="true">~$ ls blog/{currentSlug}/</p>
			<h1 class="text-3xl font-bold text-coral md:text-4xl">{category}</h1>
			<p class="mt-2 text-gray-400">{posts.length} posts</p>
		</div>

		<div class="mb-6 flex flex-wrap gap-2">
			<a
				href="/blog/"
				class="rounded-full bg-surface-3 px-3 py-1 font-mono text-xs text-gray-400 border border-transparent transition-colors hover:border-coral/30 hover:text-coral"
			>
				All
			</a>
			{
				categories.map(([cat, count]) => {
					const slug = cat.toLowerCase().replace(/\s+/g, '-');
					const isActive = slug === currentSlug;
					return (
						<a
							href={`/blog/category/${slug}/`}
							class={
								isActive
									? 'rounded-full bg-coral/20 px-3 py-1 font-mono text-xs text-coral border border-coral/30'
									: 'rounded-full bg-surface-3 px-3 py-1 font-mono text-xs text-gray-400 border border-transparent transition-colors hover:border-coral/30 hover:text-coral'
							}
						>
							{cat} <span class={isActive ? 'text-coral/60' : 'text-gray-400'}>({count})</span>
						</a>
					);
				})
			}
		</div>

		<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
			{
				posts.map((post) => (
					<BlogCard
						title={post.data.title}
						description={post.data.description}
						date={post.data.date}
						slug={post.data.slug}
						heroImage={post.data.heroImage}
						categories={post.data.categories}
						readingTime={getReadingTime(post.body || '')}
					/>
				))
			}
		</div>
	</div>
</BaseLayout>
