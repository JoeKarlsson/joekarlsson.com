---
import { getCollection } from 'astro:content';
import BlogCard from '../../components/BlogCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<BaseLayout title="Blog | Joe Karlsson" description="Posts about databases, developer tools, smart homes, and the things I build.">
	<div class="mx-auto max-w-5xl px-4 py-8">
		<div class="mb-8">
			<p class="mb-2 font-mono text-sm text-coral">$ ls ~/blog</p>
			<h1 class="text-3xl font-bold text-white md:text-4xl">Blog</h1>
			<p class="mt-2 text-gray-400">{posts.length} posts</p>
		</div>

		<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
			{posts.map((post) => (
				<BlogCard
					title={post.data.title}
					description={post.data.description}
					date={post.data.date}
					slug={post.data.slug}
					heroImage={post.data.heroImage}
				/>
			))}
		</div>
	</div>
</BaseLayout>
