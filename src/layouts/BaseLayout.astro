---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

interface Props {
	title: string;
	description: string;
	image?: string;
	type?: string;
	publishedDate?: Date;
	modifiedDate?: Date;
	schemaType?: string;
}

const { title, description, image, type, publishedDate, modifiedDate, schemaType } = Astro.props;
---

<!doctype html>
<!--
    ======================================================
    ╔══════════════════════════════════════════════╗
    ║                                              ║
    ║      ██╗ ██████╗ ███████╗                    ║
    ║      ██║██╔═══██╗██╔════╝                    ║
    ║      ██║██║   ██║█████╗                      ║
    ║ ██   ██║██║   ██║██╔══╝                      ║
    ║ ╚█████╔╝╚██████╔╝███████╗                    ║
    ║  ╚════╝  ╚═════╝ ╚══════╝                    ║
    ║                                              ║
    ║  Hey, you're looking at the source!           ║
    ║  I like your style.                          ║
    ║                                              ║
    ║  This site is built with Astro, Tailwind,    ║
    ║  and way too much coffee. No frameworks      ║
    ║  were mass-imported in the making of         ║
    ║  this website.                               ║
    ║                                              ║
    ║  Try the terminal on the homepage, or        ║
    ║  press Cmd+K anywhere for the command        ║
    ║  palette.                                    ║
    ║                                              ║
    ║  Fun fact: there are easter eggs hidden      ║
    ║  around this site. Keep exploring.           ║
    ║                                              ║
    ║  P.S. My cat says hi.  /\_/\                 ║
    ║                       ( o.o )                ║
    ║                        > ^ <                 ║
    ║                                              ║
    ╚══════════════════════════════════════════════╝
    ======================================================
-->
<html lang="en" class="dark">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={image}
			type={type}
			publishedDate={publishedDate}
			modifiedDate={modifiedDate}
			schemaType={schemaType}
		/>
	</head>
	<body class="flex min-h-screen flex-col">
		<Header />
		<main class="flex-1">
			<slot />
		</main>
		<Footer />

		<!-- ASCII Cat Cursor Tracker -->
		<div id="ascii-cat" aria-hidden="true">
			<pre
				id="ascii-cat-art"><span id="cat-face"> /\_/\
(<span id="cat-eyes">o.o</span>)
 > ^ <</span></pre>
			<div id="cat-tooltip" class="cat-tooltip-hidden">meow!</div>
		</div>

		<!-- Command Palette -->
		<div
			id="cmd-palette-overlay"
			class="cmd-palette-hidden"
			role="dialog"
			aria-modal="true"
			aria-label="Command palette"
		>
			<div id="cmd-palette" role="combobox" aria-expanded="true" aria-haspopup="listbox">
				<div id="cmd-palette-header">
					<span id="cmd-palette-prompt">&gt;</span>
					<input
						id="cmd-palette-input"
						type="text"
						placeholder="Type a command..."
						autocomplete="off"
						aria-label="Search commands"
						aria-controls="cmd-palette-list"
						aria-activedescendant=""
					/>
					<kbd id="cmd-palette-esc">ESC</kbd>
				</div>
				<ul id="cmd-palette-list" role="listbox" aria-label="Commands"></ul>
			</div>
		</div>

		<!-- Konami Code Dashboard Overlay -->
		<div
			id="konami-overlay"
			class="konami-hidden"
			role="dialog"
			aria-modal="true"
			aria-label="Homelab dashboard easter egg"
		>
			<div id="konami-dashboard">
				<div id="konami-header">
					<span id="konami-logo">GRAFANA</span>
					<span id="konami-title">Homelab Dashboard</span>
					<button id="konami-close" aria-label="Close dashboard">&times;</button>
				</div>
				<div id="konami-content">
					<div id="konami-gauges"></div>
					<div id="konami-containers"></div>
				</div>
				<div id="konami-crash" class="konami-crash-hidden">
					<pre id="konami-crash-text"></pre>
				</div>
			</div>
		</div>

		<style>
			/* ===== ASCII Cat ===== */
			#ascii-cat {
				position: fixed;
				bottom: 1.5rem;
				right: 1.5rem;
				z-index: 40;
				font-family: 'JetBrains Mono', 'Fira Code', monospace;
				font-size: 0.7rem;
				line-height: 1.15;
				color: #8bcbc8;
				cursor: pointer;
				user-select: none;
				opacity: 0.6;
				transition: opacity 0.2s;
			}
			#ascii-cat:hover {
				opacity: 1;
			}
			#ascii-cat-art {
				margin: 0;
			}
			#cat-eyes {
				display: inline;
			}
			.cat-tooltip-hidden {
				display: none;
			}
			.cat-tooltip-visible {
				display: block;
				position: absolute;
				top: -1.8rem;
				right: 0;
				background: #1a1d24;
				color: #fdae84;
				padding: 0.2rem 0.6rem;
				border-radius: 4px;
				font-size: 0.75rem;
				border: 1px solid #2a2d34;
				white-space: nowrap;
				animation: meow-pop 0.3s ease;
			}
			@keyframes meow-pop {
				0% {
					transform: scale(0.5);
					opacity: 0;
				}
				70% {
					transform: scale(1.1);
				}
				100% {
					transform: scale(1);
					opacity: 1;
				}
			}

			/* Hide cat on mobile */
			@media (max-width: 768px) {
				#ascii-cat {
					display: none;
				}
			}
			@media (pointer: coarse) {
				#ascii-cat {
					display: none;
				}
			}

			/* ===== Command Palette ===== */
			#cmd-palette-overlay.cmd-palette-hidden {
				display: none !important;
			}
			#cmd-palette-overlay {
				position: fixed;
				inset: 0;
				z-index: 9999;
				background: rgba(10, 10, 15, 0.8);
				backdrop-filter: blur(4px);
				display: flex;
				align-items: flex-start;
				justify-content: center;
				padding-top: 20vh;
			}
			#cmd-palette {
				width: 100%;
				max-width: 560px;
				background: #111318;
				border: 1px solid #2a2d34;
				border-radius: 12px;
				overflow: hidden;
				box-shadow: 0 25px 60px rgba(0, 0, 0, 0.6);
				font-family: 'JetBrains Mono', 'Fira Code', monospace;
			}
			#cmd-palette-header {
				display: flex;
				align-items: center;
				padding: 0.75rem 1rem;
				border-bottom: 1px solid #2a2d34;
				gap: 0.5rem;
			}
			#cmd-palette-prompt {
				color: #8bcbc8;
				font-size: 1rem;
				font-weight: bold;
			}
			#cmd-palette-input {
				flex: 1;
				background: transparent;
				border: none;
				outline: none;
				color: #e2e8f0;
				font-family: inherit;
				font-size: 0.9rem;
				caret-color: #fdae84;
			}
			#cmd-palette-input::placeholder {
				color: #4a4d54;
			}
			#cmd-palette-esc {
				background: #1a1d24;
				color: #6b7280;
				padding: 0.15rem 0.4rem;
				border-radius: 4px;
				font-size: 0.65rem;
				border: 1px solid #2a2d34;
			}
			#cmd-palette-list {
				list-style: none;
				margin: 0;
				padding: 0.5rem 0;
				max-height: 320px;
				overflow-y: auto;
			}
			#cmd-palette-list:empty::after {
				content: 'No results found';
				display: block;
				padding: 1rem;
				text-align: center;
				color: #4a4d54;
				font-size: 0.8rem;
			}
			#cmd-palette-list li {
				display: flex;
				align-items: center;
				padding: 0.6rem 1rem;
				cursor: pointer;
				gap: 0.75rem;
				transition: background 0.1s;
			}
			#cmd-palette-list li[aria-selected='true'],
			#cmd-palette-list li:hover {
				background: #1a1d24;
			}
			#cmd-palette-list li[aria-selected='true'] {
				border-left: 2px solid #fdae84;
			}
			.cmd-item-icon {
				font-size: 0.85rem;
				width: 1.5rem;
				text-align: center;
				flex-shrink: 0;
			}
			.cmd-item-text {
				flex: 1;
				min-width: 0;
			}
			.cmd-item-name {
				color: #e2e8f0;
				font-size: 0.85rem;
			}
			.cmd-item-desc {
				color: #6b7280;
				font-size: 0.7rem;
				margin-top: 0.1rem;
			}
			.cmd-item-shortcut {
				color: #4a4d54;
				font-size: 0.65rem;
				flex-shrink: 0;
			}

			/* ===== Konami Dashboard ===== */
			#konami-overlay.konami-hidden {
				display: none !important;
			}
			#konami-overlay {
				position: fixed;
				inset: 0;
				z-index: 9998;
				background: rgba(10, 10, 15, 0.92);
				display: flex;
				align-items: center;
				justify-content: center;
				padding: 2rem;
			}
			#konami-dashboard {
				width: 100%;
				max-width: 700px;
				background: #111318;
				border: 1px solid #2a2d34;
				border-radius: 8px;
				overflow: hidden;
				font-family: 'JetBrains Mono', 'Fira Code', monospace;
				position: relative;
			}
			#konami-header {
				display: flex;
				align-items: center;
				padding: 0.6rem 1rem;
				background: #1a1d24;
				border-bottom: 1px solid #2a2d34;
				gap: 0.75rem;
			}
			#konami-logo {
				color: #fdae84;
				font-weight: bold;
				font-size: 0.75rem;
				letter-spacing: 0.1em;
			}
			#konami-title {
				color: #6b7280;
				font-size: 0.75rem;
				flex: 1;
			}
			#konami-close {
				background: none;
				border: none;
				color: #6b7280;
				font-size: 1.2rem;
				cursor: pointer;
				padding: 0 0.25rem;
				line-height: 1;
			}
			#konami-close:hover {
				color: #e2e8f0;
			}
			#konami-content {
				padding: 1rem;
			}
			#konami-gauges {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1rem;
				margin-bottom: 1rem;
			}
			.konami-gauge {
				text-align: center;
			}
			.konami-gauge-label {
				color: #6b7280;
				font-size: 0.65rem;
				margin-bottom: 0.3rem;
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}
			.konami-gauge-bar {
				background: #0a0a0f;
				border-radius: 3px;
				height: 1.2rem;
				overflow: hidden;
				position: relative;
				border: 1px solid #2a2d34;
			}
			.konami-gauge-fill {
				height: 100%;
				border-radius: 2px;
				transition:
					width 0.5s ease,
					background-color 0.3s;
			}
			.konami-gauge-val {
				color: #8bcbc8;
				font-size: 0.7rem;
				margin-top: 0.25rem;
			}
			#konami-containers {
				border-top: 1px solid #2a2d34;
				padding-top: 0.75rem;
			}
			.konami-container-row {
				display: flex;
				align-items: center;
				padding: 0.3rem 0;
				font-size: 0.7rem;
				gap: 0.5rem;
			}
			.konami-status-dot {
				width: 6px;
				height: 6px;
				border-radius: 50%;
				background: #22c55e;
				flex-shrink: 0;
			}
			.konami-container-name {
				color: #e2e8f0;
				flex: 1;
			}
			.konami-container-status {
				color: #22c55e;
				text-transform: uppercase;
				font-size: 0.6rem;
				letter-spacing: 0.05em;
			}
			.konami-crash-hidden {
				display: none;
			}
			#konami-crash {
				position: absolute;
				inset: 0;
				background: rgba(10, 10, 15, 0.97);
				display: flex;
				align-items: center;
				justify-content: center;
				color: #ef4444;
				font-size: 0.65rem;
				padding: 1rem;
				animation: crash-in 0.3s ease;
			}
			#konami-crash pre {
				margin: 0;
				text-align: left;
				white-space: pre;
			}
			@keyframes crash-in {
				0% {
					opacity: 0;
				}
				30% {
					opacity: 1;
				}
				40% {
					opacity: 0.3;
				}
				50% {
					opacity: 1;
				}
				60% {
					opacity: 0.6;
				}
				100% {
					opacity: 1;
				}
			}

			/* Reduced motion */
			@media (prefers-reduced-motion: reduce) {
				.konami-gauge-fill {
					transition: none;
				}
				#konami-crash {
					animation: none;
				}
				@keyframes meow-pop {
					0%,
					100% {
						transform: none;
						opacity: 1;
					}
				}
				.cat-tooltip-visible {
					animation: none;
				}
			}
		</style>

		<script>
			(function () {
				// ===== Utilities =====
				const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

				// ===== ASCII Cat Eye Tracking =====
				const catEl = document.getElementById('ascii-cat');
				const catEyes = document.getElementById('cat-eyes');
				const catTooltip = document.getElementById('cat-tooltip');

				if (catEl && catEyes) {
					const eyeStates = [
						{ left: '-', right: '-', label: 'far left' },
						{ left: 'o', right: 'o', label: 'center' },
						{ left: '-', right: 'o', label: 'left' },
						{ left: 'o', right: '-', label: 'right' },
						{ left: '^', right: '^', label: 'up' },
						{ left: 'v', right: 'v', label: 'down' },
					];

					function updateEyes(clientX, clientY) {
						if (prefersReducedMotion.matches) return;
						const rect = catEl.getBoundingClientRect();
						const catCX = rect.left + rect.width / 2;
						const catCY = rect.top + rect.height / 2;
						const dx = clientX - catCX;
						const dy = clientY - catCY;
						const angle = Math.atan2(dy, dx);
						const deg = (angle * 180) / Math.PI;

						let left, right;
						if (deg < -120 || deg > 120) {
							// Looking left
							left = '-';
							right = 'o';
						} else if (deg > -60 && deg < 60) {
							// Looking right
							left = 'o';
							right = '-';
						} else if (deg <= -60) {
							// Looking up
							left = '^';
							right = '^';
						} else {
							// Looking down
							left = 'v';
							right = 'v';
						}
						catEyes.textContent = left + '.' + right;
					}

					let eyeRaf = 0;
					document.addEventListener('mousemove', function (e) {
						cancelAnimationFrame(eyeRaf);
						eyeRaf = requestAnimationFrame(function () {
							updateEyes(e.clientX, e.clientY);
						});
					});

					// Meow on click
					catEl.addEventListener('click', function () {
						if (catTooltip) {
							catTooltip.className = 'cat-tooltip-visible';
							clearTimeout(catEl._meowTimer);
							catEl._meowTimer = setTimeout(function () {
								catTooltip.className = 'cat-tooltip-hidden';
							}, 1500);
						}
					});
				}

				// ===== Command Palette =====
				const commands = [
					{
						name: 'Home',
						desc: 'Go to homepage',
						icon: '~',
						action: function () {
							window.location.href = '/';
						},
					},
					{
						name: 'Blog',
						desc: 'Browse blog posts',
						icon: '>',
						action: function () {
							window.location.href = '/blog';
						},
					},
					{
						name: 'About',
						desc: 'About Joe Karlsson',
						icon: '?',
						action: function () {
							window.location.href = '/about';
						},
					},
					{
						name: 'Work',
						desc: 'Work and projects',
						icon: '#',
						action: function () {
							window.location.href = '/work';
						},
					},
					{
						name: 'Uses',
						desc: 'Tools and setup',
						icon: '$',
						action: function () {
							window.location.href = '/uses';
						},
					},
					{
						name: 'Contact',
						desc: 'Get in touch',
						icon: '@',
						action: function () {
							window.location.href = '/contact';
						},
					},
					{
						name: 'Talk Archive',
						desc: 'Past talks and presentations',
						icon: '%',
						action: function () {
							window.location.href = '/talk-archive';
						},
					},
					{
						name: 'RSS Feed',
						desc: 'Subscribe via RSS',
						icon: '*',
						action: function () {
							window.location.href = '/rss.xml';
						},
					},
					{
						name: 'Konami Code',
						desc: 'Trigger the secret dashboard',
						icon: '!',
						action: function () {
							triggerKonami();
							closePalette();
						},
					},
					{
						name: 'Matrix Rain',
						desc: 'Digital rain effect',
						icon: '&',
						action: function () {
							triggerMatrixRain();
							closePalette();
						},
					},
				];

				const overlay = document.getElementById('cmd-palette-overlay');
				const input = document.getElementById('cmd-palette-input');
				const list = document.getElementById('cmd-palette-list');
				let paletteOpen = false;
				let selectedIndex = 0;
				let filteredCommands = [];
				let previousFocus = null;

				function openPalette() {
					if (paletteOpen) return;
					paletteOpen = true;
					previousFocus = document.activeElement;
					overlay.classList.remove('cmd-palette-hidden');
					overlay.style.display = 'flex';
					input.value = '';
					selectedIndex = 0;
					renderCommands('');
					requestAnimationFrame(function () {
						input.focus();
					});
				}

				function closePalette() {
					if (!paletteOpen) return;
					paletteOpen = false;
					overlay.classList.add('cmd-palette-hidden');
					overlay.style.display = 'none';
					if (previousFocus) previousFocus.focus();
				}

				function renderCommands(query) {
					var q = query.toLowerCase().trim();
					filteredCommands = q
						? commands.filter(function (c) {
								return c.name.toLowerCase().includes(q) || c.desc.toLowerCase().includes(q);
							})
						: commands.slice();

					list.innerHTML = '';
					filteredCommands.forEach(function (cmd, i) {
						var li = document.createElement('li');
						li.setAttribute('role', 'option');
						li.id = 'cmd-item-' + i;
						li.setAttribute('aria-selected', i === selectedIndex ? 'true' : 'false');
						li.innerHTML =
							'<span class="cmd-item-icon">' +
							cmd.icon +
							'</span>' +
							'<div class="cmd-item-text">' +
							'<div class="cmd-item-name">' +
							cmd.name +
							'</div>' +
							'<div class="cmd-item-desc">' +
							cmd.desc +
							'</div>' +
							'</div>';
						li.addEventListener('click', function () {
							cmd.action();
						});
						li.addEventListener('mouseenter', function () {
							selectedIndex = i;
							updateSelection();
						});
						list.appendChild(li);
					});
					if (filteredCommands.length > 0 && selectedIndex >= filteredCommands.length) {
						selectedIndex = 0;
					}
					updateSelection();
				}

				function updateSelection() {
					var items = list.querySelectorAll('li');
					items.forEach(function (li, i) {
						li.setAttribute('aria-selected', i === selectedIndex ? 'true' : 'false');
					});
					var active = items[selectedIndex];
					if (active) {
						input.setAttribute('aria-activedescendant', active.id);
						active.scrollIntoView({ block: 'nearest' });
					}
				}

				function executeSelected() {
					if (filteredCommands[selectedIndex]) {
						filteredCommands[selectedIndex].action();
					}
				}

				// Keyboard shortcut to open
				document.addEventListener('keydown', function (e) {
					if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
						e.preventDefault();
						if (paletteOpen) {
							closePalette();
						} else {
							openPalette();
						}
					}
				});

				if (overlay) {
					// Close on overlay click
					overlay.addEventListener('mousedown', function (e) {
						if (e.target === overlay) closePalette();
					});
				}

				if (input) {
					input.addEventListener('input', function () {
						selectedIndex = 0;
						renderCommands(input.value);
					});

					input.addEventListener('keydown', function (e) {
						if (e.key === 'Escape') {
							e.preventDefault();
							closePalette();
						} else if (e.key === 'ArrowDown') {
							e.preventDefault();
							if (filteredCommands.length > 0) {
								selectedIndex = (selectedIndex + 1) % filteredCommands.length;
								updateSelection();
							}
						} else if (e.key === 'ArrowUp') {
							e.preventDefault();
							if (filteredCommands.length > 0) {
								selectedIndex =
									(selectedIndex - 1 + filteredCommands.length) % filteredCommands.length;
								updateSelection();
							}
						} else if (e.key === 'Enter') {
							e.preventDefault();
							executeSelected();
						} else if (e.key === 'Tab') {
							e.preventDefault(); // Trap focus
						}
					});
				}

				// ===== Konami Code =====
				var konamiSequence = [
					'ArrowUp',
					'ArrowUp',
					'ArrowDown',
					'ArrowDown',
					'ArrowLeft',
					'ArrowRight',
					'ArrowLeft',
					'ArrowRight',
					'b',
					'a',
				];
				var konamiIndex = 0;

				document.addEventListener('keydown', function (e) {
					if (paletteOpen) return; // Don't capture when palette is open
					var expected = konamiSequence[konamiIndex];
					if (e.key === expected || e.key.toLowerCase() === expected) {
						konamiIndex++;
						if (konamiIndex === konamiSequence.length) {
							konamiIndex = 0;
							triggerKonami();
						}
					} else {
						konamiIndex = 0;
					}
				});

				var konamiOverlay = document.getElementById('konami-overlay');
				var konamiGauges = document.getElementById('konami-gauges');
				var konamiContainers = document.getElementById('konami-containers');
				var konamiCrash = document.getElementById('konami-crash');
				var konamiCrashText = document.getElementById('konami-crash-text');
				if (konamiCrashText) {
					konamiCrashText.textContent =
						"  ___  ___  __  __   _  ___ _ _        _\n / _ \\/ _ \\|  \\/  | | |/ (_) | |___ __| |\n| (_) | (_) | |\\/| | | ' <| | | / -_) _` |\n \\___/ \\___/|_|  |_| |_|\\_\\_|_|_\\___\\__,_|\n\nFATAL: out of memory\nkernel: Out of memory: Killed process 31337 (grafana)\nkernel: Killed process 31338 (prometheus)\nkernel: Killed process 31339 (node-exporter)\n\nTotal memory: 4096MB\nUsed: 4095MB\nAvailable: 1MB\n\n...system halted.";
				}
				var konamiCloseBtn = document.getElementById('konami-close');
				var konamiTimers = [];

				function clearKonamiTimers() {
					konamiTimers.forEach(function (t) {
						clearTimeout(t);
						clearInterval(t);
					});
					konamiTimers = [];
				}

				function closeKonami() {
					clearKonamiTimers();
					konamiOverlay.classList.add('konami-hidden');
					konamiOverlay.style.display = 'none';
					konamiCrash.classList.add('konami-crash-hidden');
					konamiCrash.style.display = 'none';
				}

				if (konamiCloseBtn) {
					konamiCloseBtn.addEventListener('click', closeKonami);
				}

				function triggerKonami() {
					clearKonamiTimers();
					konamiOverlay.classList.remove('konami-hidden');
					konamiOverlay.style.display = 'flex';
					konamiCrash.classList.add('konami-crash-hidden');
					konamiCrash.style.display = 'none';

					// Build gauges
					var gaugeData = [
						{ label: 'CPU', value: 23 },
						{ label: 'Memory', value: 41 },
						{ label: 'Disk', value: 67 },
					];
					konamiGauges.innerHTML = '';
					var gaugeFills = [];
					gaugeData.forEach(function (g) {
						var div = document.createElement('div');
						div.className = 'konami-gauge';
						div.innerHTML =
							'<div class="konami-gauge-label">' +
							g.label +
							'</div>' +
							'<div class="konami-gauge-bar"><div class="konami-gauge-fill" style="width:' +
							g.value +
							'%;background:#8bcbc8;"></div></div>' +
							'<div class="konami-gauge-val">' +
							g.value +
							'%</div>';
						konamiGauges.appendChild(div);
						gaugeFills.push({
							fill: div.querySelector('.konami-gauge-fill'),
							valEl: div.querySelector('.konami-gauge-val'),
							value: g.value,
						});
					});

					// Build containers
					var containers = [
						'plex',
						'jellyfin',
						'home-assistant',
						'mosquitto',
						'zigbee2mqtt',
						'caddy',
						'grafana',
						'prometheus',
						'portainer',
					];
					konamiContainers.innerHTML = '';
					containers.forEach(function (name) {
						var row = document.createElement('div');
						row.className = 'konami-container-row';
						row.innerHTML =
							'<span class="konami-status-dot"></span>' +
							'<span class="konami-container-name">' +
							name +
							'</span>' +
							'<span class="konami-container-status">running</span>';
						konamiContainers.appendChild(row);
					});

					// Animate gauges climbing
					var interval = setInterval(
						function () {
							gaugeFills.forEach(function (g) {
								g.value = Math.min(99, g.value + Math.floor(Math.random() * 8 + 2));
								g.fill.style.width = g.value + '%';
								g.valEl.textContent = g.value + '%';
								if (g.value > 80) {
									g.fill.style.backgroundColor = g.value > 90 ? '#ef4444' : '#fdae84';
								}
							});
						},
						prefersReducedMotion.matches ? 800 : 400,
					);
					konamiTimers.push(interval);

					// OOM crash after delay
					var crashDelay = prefersReducedMotion.matches ? 2500 : 3500;
					var crashTimer = setTimeout(function () {
						clearInterval(interval);
						// Turn all containers red
						var dots = konamiContainers.querySelectorAll('.konami-status-dot');
						var statuses = konamiContainers.querySelectorAll('.konami-container-status');
						dots.forEach(function (d) {
							d.style.background = '#ef4444';
						});
						statuses.forEach(function (s) {
							s.textContent = 'killed';
							s.style.color = '#ef4444';
						});
						// Show crash screen
						konamiCrash.classList.remove('konami-crash-hidden');
						konamiCrash.style.display = 'flex';
					}, crashDelay);
					konamiTimers.push(crashTimer);

					// Auto close after crash
					var autoClose = setTimeout(function () {
						closeKonami();
					}, crashDelay + 5000);
					konamiTimers.push(autoClose);

					// Focus trap + Escape
					konamiCloseBtn.focus();
				}

				if (konamiOverlay) {
					konamiOverlay.addEventListener('keydown', function (e) {
						if (e.key === 'Escape') {
							e.preventDefault();
							closeKonami();
						}
						if (e.key === 'Tab') {
							e.preventDefault(); // Trap focus
							konamiCloseBtn.focus();
						}
					});
					konamiOverlay.addEventListener('mousedown', function (e) {
						if (e.target === konamiOverlay) closeKonami();
					});
				}

				// ===== Matrix Rain Easter Egg =====
				function triggerMatrixRain() {
					var canvas = document.createElement('canvas');
					canvas.id = 'matrix-rain-canvas';
					canvas.style.cssText =
						'position:fixed;inset:0;z-index:9997;pointer-events:none;opacity:0.7;';
					document.body.appendChild(canvas);
					var ctx = canvas.getContext('2d');
					canvas.width = window.innerWidth;
					canvas.height = window.innerHeight;

					var columns = Math.floor(canvas.width / 14);
					var drops = [];
					for (var i = 0; i < columns; i++) {
						drops[i] = Math.floor((Math.random() * -canvas.height) / 14);
					}
					var chars =
						'アイウエオカキクケコサシスセソタチツテトナニヌネノハヒフヘホマミムメモヤユヨラリルレロワヲン0123456789';

					function draw() {
						ctx.fillStyle = 'rgba(10, 10, 15, 0.05)';
						ctx.fillRect(0, 0, canvas.width, canvas.height);
						ctx.fillStyle = '#8bcbc8';
						ctx.font = '12px monospace';
						for (var i = 0; i < drops.length; i++) {
							var char = chars[Math.floor(Math.random() * chars.length)];
							ctx.fillText(char, i * 14, drops[i] * 14);
							if (drops[i] * 14 > canvas.height && Math.random() > 0.975) {
								drops[i] = 0;
							}
							drops[i]++;
						}
					}

					var matrixInterval = setInterval(draw, prefersReducedMotion.matches ? 100 : 33);
					setTimeout(function () {
						clearInterval(matrixInterval);
						canvas.remove();
					}, 5000);
				}
			})();
		</script>
	</body>
</html>
