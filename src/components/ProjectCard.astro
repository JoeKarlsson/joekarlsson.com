---
import type { Project } from '../data/projects';
import { CATEGORY_META } from '../data/projects';

interface Props {
	project: Project;
}

const { project } = Astro.props;
const meta = CATEGORY_META[project.category];
const primaryUrl = project.sourceUrl || project.blogUrl || project.demoUrl || '#';
const isExternal = primaryUrl.startsWith('http');
---

<div
	class="group relative block overflow-hidden rounded-lg border border-surface-3 bg-surface-1 transition-all duration-300 hover:-translate-y-0.5 hover:border-coral/30 hover:bg-surface-2 {meta.borderColor} {meta.shadowColor}"
>
	<a
		href={primaryUrl}
		target={isExternal ? '_blank' : undefined}
		rel={isExternal ? 'noopener noreferrer' : undefined}
		class="block no-underline"
	>
		<img
			src={project.image}
			alt={project.imageAlt}
			class="h-44 w-full rounded-md object-cover transition-transform duration-300 group-hover:scale-105"
			loading="lazy"
		/>
		<div class="p-4">
			<div class="mb-1 flex items-center justify-between">
				<h3 class={`font-semibold text-white ${meta.hoverColor}`}>{project.title}</h3>
				{project.stars && <span class="text-xs text-gray-400">{project.stars} stars</span>}
			</div>
			<div class="mb-2 flex flex-wrap gap-1">
				{
					project.tech.map((t) => (
						<span class="rounded-full bg-surface-3 px-2 py-0.5 font-mono text-[10px] text-gray-400">
							{t}
						</span>
					))
				}
			</div>
			<p class="text-sm text-gray-400 line-clamp-3">{project.description}</p>
		</div>
	</a>
	{
		(project.sourceUrl || project.demoUrl || project.blogUrl) && (
			<div class="flex items-center gap-3 border-t border-surface-3 px-4 py-2">
				{project.sourceUrl && (
					<a
						href={project.sourceUrl}
						target="_blank"
						rel="noopener noreferrer"
						class="flex items-center gap-1 font-mono text-xs text-gray-400 no-underline transition-colors hover:text-coral"
					>
						<svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24">
							<path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
						</svg>
						Source
					</a>
				)}
				{project.demoUrl && (
					<a
						href={project.demoUrl}
						target="_blank"
						rel="noopener noreferrer"
						class="flex items-center gap-1 font-mono text-xs text-gray-400 no-underline transition-colors hover:text-coral"
					>
						<svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
							/>
						</svg>
						Demo
					</a>
				)}
				{project.blogUrl && (
					<a
						href={project.blogUrl}
						class="flex items-center gap-1 font-mono text-xs text-gray-400 no-underline transition-colors hover:text-coral"
					>
						<svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"
							/>
						</svg>
						Blog Post
					</a>
				)}
			</div>
		)
	}
</div>
