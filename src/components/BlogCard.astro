---
interface Props {
	title: string;
	description: string;
	date: Date;
	slug: string;
	heroImage?: string;
}

const { title, description, date, slug, heroImage } = Astro.props;
const formattedDate = date.toLocaleDateString('en-us', {
	year: 'numeric',
	month: 'short',
	day: 'numeric',
});
---

<a href={`/blog/${slug}/`} class="group block rounded-lg border border-surface-3 bg-surface-1 p-4 no-underline transition-all hover:border-coral/30 hover:bg-surface-2">
	{heroImage && (
		<img
			src={heroImage}
			alt=""
			class="mb-3 h-40 w-full rounded-md object-cover"
			loading="lazy"
		/>
	)}
	<p class="mb-1 font-mono text-xs text-gray-500">{formattedDate}</p>
	<h3 class="mb-2 text-lg font-semibold text-white group-hover:text-coral transition-colors">
		{title}
	</h3>
	{description && (
		<p class="line-clamp-2 text-sm text-gray-400">{description}</p>
	)}
</a>
