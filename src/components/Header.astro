---
import { NAV_LINKS, SOCIAL_LINKS } from '../consts';

const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.replace(/\/$/, '') || '/';

function isActive(href: string): boolean {
	const normalizedHref = href.replace(/\/$/, '') || '/';
	if (normalizedHref === '/') return currentPath === '/';
	return currentPath === normalizedHref || currentPath.startsWith(normalizedHref);
}
---

<header class="sticky top-0 z-50 border-b border-surface-3 bg-surface-0/80 backdrop-blur-md">
	<nav class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
		<a href="/" class="group flex items-center gap-2 no-underline">
			<span class="text-lg font-bold text-white group-hover:text-coral">Joe Karlsson</span>
		</a>

		<div class="hidden items-center gap-1 md:flex">
			{
				NAV_LINKS.map(({ href, label }) => (
					<a
						href={href}
						class:list={[
							'rounded-md px-3 py-1.5 text-sm font-medium no-underline',
							isActive(href) ? 'bg-surface-3 text-coral' : 'text-gray-400',
						]}
					>
						{label}
					</a>
				))
			}
		</div>

		<div class="flex items-center gap-3">
			<!-- Interactive dot grid -->
			<canvas id="dot-grid" class="hidden md:block" width="120" height="28" style="cursor: default;"
			></canvas>

			<a
				href={SOCIAL_LINKS.github}
				target="_blank"
				rel="noopener noreferrer"
				class="text-gray-400 hover:text-coral"
				aria-label="GitHub"
			>
				<svg viewBox="0 0 16 16" width="20" height="20" fill="currentColor">
					<path
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path>
				</svg>
			</a>
			<a
				href={SOCIAL_LINKS.linkedin}
				target="_blank"
				rel="noopener noreferrer"
				class="text-gray-400 hover:text-coral"
				aria-label="LinkedIn"
			>
				<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
					<path
						d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
					></path>
				</svg>
			</a>
			<a
				href={SOCIAL_LINKS.bluesky}
				target="_blank"
				rel="noopener noreferrer"
				class="text-gray-400 hover:text-coral"
				aria-label="Bluesky"
			>
				<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
					<path
						d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.785 2.627 3.6 3.476 6.154 3.229-4.058.746-7.329 2.453-2.869 6.151 5.203 3.947 7.027-1.082 8.091-3.637.163-.39.24-.576.24-.41 0-.166.076.02.24.41 1.064 2.555 2.888 7.584 8.091 3.637 4.46-3.698 1.189-5.405-2.869-6.151 2.554.247 5.37-.602 6.154-3.229C24.002 9.418 24.38 4.458 24.38 3.768c0-.69-.139-1.861-.902-2.203-.659-.3-1.664-.621-4.3 1.24C16.426 4.747 13.087 8.686 12 10.8z"
					></path>
				</svg>
			</a>
			<a
				href={SOCIAL_LINKS.letterboxd}
				target="_blank"
				rel="noopener noreferrer"
				class="text-gray-400 hover:text-coral"
				aria-label="Letterboxd"
			>
				<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
					<path
						d="M8.224 14.352a4.773 4.773 0 0 1-3.2-4.46 4.773 4.773 0 0 1 3.2-4.46A4.769 4.769 0 0 0 6.4 4.8a4.8 4.8 0 1 0 0 9.6c.66 0 1.29-.134 1.862-.375l-.038.327zm7.552 0a4.773 4.773 0 0 0 3.2-4.46 4.773 4.773 0 0 0-3.2-4.46A4.769 4.769 0 0 1 17.6 4.8a4.8 4.8 0 1 1 0 9.6 4.769 4.769 0 0 1-1.862-.375l.038.327zM12 14.4a4.773 4.773 0 0 1-3.776-4.508A4.773 4.773 0 0 1 12 5.384a4.773 4.773 0 0 1 3.776 4.508A4.773 4.773 0 0 1 12 14.4z"
					></path>
				</svg>
			</a>

			<!-- Mobile menu button -->
			<button
				id="mobile-menu-btn"
				class="rounded-md p-1.5 text-gray-400 hover:bg-surface-2 hover:text-coral md:hidden"
				aria-label="Toggle menu"
			>
				<svg
					width="20"
					height="20"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
				>
					<path d="M3 12h18M3 6h18M3 18h18"></path>
				</svg>
			</button>
		</div>
	</nav>

	<!-- Mobile menu -->
	<div id="mobile-menu" class="hidden border-t border-surface-3 bg-surface-1 px-4 py-2 md:hidden">
		{
			NAV_LINKS.map(({ href, label }) => (
				<a
					href={href}
					class:list={[
						'block rounded-md px-3 py-2 text-sm no-underline',
						isActive(href) ? 'text-coral' : 'text-gray-400 hover:text-white',
					]}
				>
					{label}
				</a>
			))
		}
	</div>
</header>

<script>
	const btn = document.getElementById('mobile-menu-btn');
	const menu = document.getElementById('mobile-menu');
	btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));

	// Dot grid animation
	const canvas = document.getElementById('dot-grid') as HTMLCanvasElement;
	if (canvas) {
		const ctx = canvas.getContext('2d')!;
		const cols = 15;
		const rows = 3;
		const spacingX = canvas.width / cols;
		const spacingY = canvas.height / rows;
		const radius = 1.5;
		const pushRadius = 30;
		const springBack = 0.08;

		interface Dot {
			baseX: number;
			baseY: number;
			x: number;
			y: number;
			vx: number;
			vy: number;
			displaced: number;
		}

		const dots: Dot[] = [];
		for (let r = 0; r < rows; r++) {
			for (let c = 0; c < cols; c++) {
				const baseX = spacingX * (c + 0.5);
				const baseY = spacingY * (r + 0.5);
				dots.push({ baseX, baseY, x: baseX, y: baseY, vx: 0, vy: 0, displaced: 0 });
			}
		}

		let mouseX = -100;
		let mouseY = -100;
		let isAnimating = false;
		let animationId: number | null = null;
		let settleFrames = 0;

		canvas.addEventListener('mousemove', (e) => {
			const rect = canvas.getBoundingClientRect();
			mouseX = e.clientX - rect.left;
			mouseY = e.clientY - rect.top;
			settleFrames = 0;
			if (!isAnimating) {
				isAnimating = true;
				animate();
			}
		});
		canvas.addEventListener('mouseleave', () => {
			mouseX = -100;
			mouseY = -100;
		});

		// Colors
		const baseColor = 'rgba(136, 136, 136, 0.3)';
		const activeColor = '#fdae84'; // coral

		// Draw initial static state
		function drawStatic() {
			ctx.clearRect(0, 0, canvas.width, canvas.height);
			for (const dot of dots) {
				ctx.beginPath();
				ctx.arc(dot.baseX, dot.baseY, radius, 0, Math.PI * 2);
				ctx.fillStyle = baseColor;
				ctx.globalAlpha = 0.3;
				ctx.fill();
				ctx.globalAlpha = 1;
			}
		}

		function animate() {
			ctx.clearRect(0, 0, canvas.width, canvas.height);
			let totalMotion = 0;

			for (const dot of dots) {
				const dx = dot.x - mouseX;
				const dy = dot.y - mouseY;
				const dist = Math.sqrt(dx * dx + dy * dy);

				if (dist < pushRadius && dist > 0) {
					const force = (pushRadius - dist) / pushRadius;
					dot.vx += (dx / dist) * force * 2;
					dot.vy += (dy / dist) * force * 2;
				}

				// Spring back
				dot.vx += (dot.baseX - dot.x) * springBack;
				dot.vy += (dot.baseY - dot.y) * springBack;

				// Damping
				dot.vx *= 0.85;
				dot.vy *= 0.85;

				dot.x += dot.vx;
				dot.y += dot.vy;

				// Track displacement for color
				const displacement = Math.sqrt((dot.x - dot.baseX) ** 2 + (dot.y - dot.baseY) ** 2);
				dot.displaced = Math.min(displacement / 8, 1);
				totalMotion += Math.abs(dot.vx) + Math.abs(dot.vy);

				ctx.beginPath();
				ctx.arc(dot.x, dot.y, radius + dot.displaced * 0.5, 0, Math.PI * 2);
				ctx.fillStyle = dot.displaced > 0.1 ? activeColor : baseColor;
				ctx.globalAlpha = 0.3 + dot.displaced * 0.7;
				ctx.fill();
				ctx.globalAlpha = 1;
			}

			// Stop animating once dots have settled back to rest
			if (totalMotion < 0.01 && mouseX === -100) {
				settleFrames++;
				if (settleFrames > 10) {
					isAnimating = false;
					drawStatic();
					return;
				}
			} else {
				settleFrames = 0;
			}

			animationId = requestAnimationFrame(animate);
		}

		drawStatic();
	}
</script>
