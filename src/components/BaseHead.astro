---
import '../styles/global.css';
import { SITE_TITLE, SITE_URL } from '../consts';

interface Props {
	title: string;
	description: string;
	image?: string;
	type?: string;
	publishedDate?: Date;
	modifiedDate?: Date;
	schemaType?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const {
	title,
	description,
	image = '/images/og-default.webp',
	type = 'website',
	publishedDate,
	modifiedDate,
	schemaType,
} = Astro.props;

const ogImageURL = new URL(image, Astro.site);
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta
	name="robots"
	content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
/>

<!-- Fonts (non-render-blocking) -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
	rel="preload"
	as="style"
	href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap"
/>
<link
	rel="stylesheet"
	href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap"
	media="print"
	onload="this.media='all'"
/>
<noscript
	><link
		rel="stylesheet"
		href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap"
	/></noscript
>

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
<meta name="theme-color" content="#0a0a0a" />

<!-- Sitemap & RSS -->
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>

<!-- SEO -->
<link rel="canonical" href={canonicalURL} />
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
{type === 'article' && <meta name="author" content="Joe Karlsson" />}

<!-- Search engine verification (preserved from WordPress) -->
<meta name="google-site-verification" content="QRPrUDjca6IhevyDBOqQCygKZqp45Xyrr2HZooS1LSE" />
<meta name="msvalidate.01" content="BA95135B22E369C003B007BEE5ECC2F2" />
<meta name="p:domain_verify" content="9557bed697f311b040f7e3c0f2c7c503" />
<meta name="yandex-verification" content="993d1db38acd907f" />

<!-- Open Graph -->
<meta property="og:locale" content="en_US" />
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={title} />
{
	type === 'article' && (
		<meta property="article:author" content="https://www.joekarlsson.com/about/" />
	)
}
{publishedDate && <meta property="article:published_time" content={publishedDate.toISOString()} />}
{modifiedDate && <meta property="article:modified_time" content={modifiedDate.toISOString()} />}
{
	type === 'article' && (
		<meta property="article:publisher" content="https://www.facebook.com/joe.karlsson13" />
	)
}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL} />
<meta name="twitter:site" content="@joekarlsson1" />
<meta name="twitter:creator" content="@joekarlsson1" />

<!-- JSON-LD Structured Data -->
<script
	type="application/ld+json"
	set:html={JSON.stringify({
		'@context': 'https://schema.org',
		'@graph': [
			{
				'@type': 'WebSite',
				'@id': `${SITE_URL}/#website`,
				url: SITE_URL,
				name: SITE_TITLE,
				description: 'Software Engineer and Developer Advocate.',
				publisher: { '@id': `${SITE_URL}/#/schema/person` },
				inLanguage: 'en-US',
			},
			{
				'@type': 'Person',
				'@id': `${SITE_URL}/#/schema/person`,
				name: 'Joe Karlsson',
				url: SITE_URL,
				jobTitle: 'Developer Advocate',
				worksFor: {
					'@type': 'Organization',
					name: 'CloudQuery',
				},
				description:
					'Joe Karlsson is a Software Engineer and Developer Advocate. TEDx Speaker, film buff, and homelab enthusiast.',
				image: {
					'@type': 'ImageObject',
					url: `${SITE_URL}/images/joe-profile.webp`,
					contentUrl: `${SITE_URL}/images/joe-profile.webp`,
				},
				sameAs: [
					'https://www.joekarlsson.com',
					'https://www.facebook.com/joe.karlsson13',
					'https://www.instagram.com/joekarlsson/',
					'https://www.linkedin.com/in/joekarlsson/',
					'https://bsky.app/profile/joekarlsson.com',
					'https://www.youtube.com/joekarlsson',
					'https://github.com/JoeKarlsson',
					'https://www.threads.net/@joekarlsson',
					'https://letterboxd.com/joekarlsson/',
				],
			},
			...(type === 'article' && publishedDate
				? [
						{
							'@type': 'BlogPosting',
							headline: title,
							description: description,
							image: ogImageURL.toString(),
							datePublished: publishedDate.toISOString(),
							...(modifiedDate ? { dateModified: modifiedDate.toISOString() } : {}),
							author: { '@id': `${SITE_URL}/#/schema/person` },
							publisher: { '@id': `${SITE_URL}/#/schema/person` },
							mainEntityOfPage: {
								'@type': 'WebPage',
								'@id': canonicalURL.toString(),
							},
							inLanguage: 'en-US',
						},
					]
				: []),
			...(type === 'article'
				? [
						{
							'@type': 'BreadcrumbList',
							itemListElement: [
								{
									'@type': 'ListItem',
									position: 1,
									name: 'Home',
									item: SITE_URL,
								},
								{
									'@type': 'ListItem',
									position: 2,
									name: 'Blog',
									item: `${SITE_URL}/blog/`,
								},
								{
									'@type': 'ListItem',
									position: 3,
									name: title,
								},
							],
						},
					]
				: []),
			...(schemaType && type !== 'article'
				? [
						{
							'@type': schemaType,
							'@id': canonicalURL.toString(),
							url: canonicalURL.toString(),
							name: title,
							description: description,
							isPartOf: { '@id': `${SITE_URL}/#website` },
							about: { '@id': `${SITE_URL}/#/schema/person` },
							inLanguage: 'en-US',
						},
					]
				: []),
		],
	})}
/>

<!-- Plausible Analytics (self-hosted) -->
<script defer data-domain="joekarlsson.com" src="https://plausible.joekarlsson.com/js/script.js"
></script>
